@{
    ViewBag.Title = "Dashboard";
}

<style>
    body {
        background-color: #262730;
        /*background-color: #01172f;*/

        color: #ffffff;
    }

    .section {
        opacity: 1;
        transition: all 0.8s;
    }

    .section.hiden {
        opacity: 0;
        transition: all 0.8s;
    }

    .selection-1 {
        text-align: center;
        margin-top: 40px;
        margin-bottom: 60px;
        font-size: 70px;
        font-weight: bold;
        line-height: 65px;
    }

    .selection-1 .head-title {
        font-size: 25px;
    }

    .selection-2 {

    }

        .selection-2 .item-box {
            text-align: center;
            border-radius: 8px;
            border: 8px solid;
            margin-bottom: 25px;
            position: relative;
            transition: all 0.8s
        }

            .selection-2 .item-box.man-box {
                border-color: rgb(157, 228, 129);
            }
                .selection-2 .item-box.man-box .box-detail {
                    border-color: rgb(157, 228, 129);
                }

            .selection-2 .item-box.mc-box {
                border-color: rgb(216, 17, 89);
            }
                .selection-2 .item-box.mc-box .box-detail {
                    border-color: rgb(216, 17, 89);
                }

            .selection-2 .item-box.mold-box {
                border-color: rgb(138, 25, 127);
            }
                .selection-2 .item-box.mold-box .box-detail {
                    border-color: rgb(138, 25, 127);
                }

            .selection-2 .item-box.met-box {
                border-color: rgb(145, 166, 255);
            }
                .selection-2 .item-box.met-box .box-detail {
                    border-color: rgb(145, 166, 255);
                }

            .selection-2 .item-box.part-box {
                border-color: rgb(115, 210, 222);
            }
                .selection-2 .item-box.part-box .box-detail {
                    border-color: rgb(115, 210, 222);
                }

            .selection-2 .item-box .box-img {
            }

                .selection-2 .item-box .box-img img {
                    height: 80px;
                    width: 80px;
                    object-fit: cover;
                    background: #ffffff;
                    border-radius: 100%;
                    border: 5px solid rgb(177 177 177);
                    position: absolute;
                    top: 10px;
                    left: 10px;
                    transition: all 0.8s
                }

            .selection-2 .item-box .box-title {
                font-size: 40px;
                font-weight: bold;
                line-height: normal;
            }

            .selection-2 .item-box .box-detail {
                font-size: 120px;
                font-weight: bold;
                line-height: normal;
                border-bottom: 3px solid;
                margin: 0 25px;
            }


    .selection-3 {
        position: fixed;
        bottom: 0;
        width: 100%;
    }

        .selection-3 .progress {
            border-radius: unset;
            height: 10px;
        }


        @Html.Raw("@media only screen and (max-width: 992px)") {
          .selection-2 .item-box .box-img img {
                height: 50px;
                width: 50px;
                border: 3px solid rgb(177 177 177);
            }
        }
</style>

<div id="MainApp" style="display: none;" >
    <div class="section selection-1" :class="{ hide: isHide }">
        Change Point : {{txt_head}}
    </div>

    <div class="section selection-2" :class="{ hide: isHide }">
        <div class="container-fluid">
            <div class="row">

                <div class="col-md-4">
                    <div class="item-box man-box">

                        <div class="box-img">
                            <img src="~/src/icons/man.png" alt="man" />
                        </div>

                        <div class="box-detail">{{count_no_man}}</div>

                        <div class="box-title">Man</div>

                    </div>
                </div>

                <div class="col-md-4 col-sm-6">
                    <div class="item-box mc-box">

                        <div class="box-img">
                            <img src="~/src/icons/conveyor.png" alt="mc" />
                        </div>

                        <div class="box-detail">{{count_no_mc}}</div>

                        <div class="box-title">Machine</div>

                    </div>
                </div>
                <div class="col-md-4 col-sm-6">
                    <div class="item-box mold-box">

                        <div class="box-img">
                            <img src="~/src/icons/molding-machine.png" alt="mold" />
                        </div>

                        <div class="box-detail">{{count_no_mold}}</div>

                        <div class="box-title">Mold/DIE</div>

                    </div>
                </div>
                <div class="col-md-4 col-sm-6 offset-md-2">
                    <div class="item-box met-box">

                        <div class="box-img">
                            <img src="~/src/icons/strategic-plan.png" alt="met" />
                        </div>

                        <div class="box-detail">{{count_no_met}}</div>

                        <div class="box-title">Method</div>

                    </div>
                </div>
                <div class="col-md-4 col-sm-6">
                    <div class="item-box part-box">

                        <div class="box-img">
                            <img src="~/src/icons/raw-material.png" alt="part" />
                        </div>

                        <div class="box-detail">{{count_no_part}}</div>

                        <div class="box-title">Part/Mat'l</div>

                    </div>
                </div>


            </div>
        </div>
    </div>

    <div class="section selection-3" :class="{ hide: isHide }">
        <div class="progress">
            <div class="progress-bar progress-bar-striped progress-bar-animated" v-bind:style="{ width: progressive_bar }" role="progressbar" aria-valuenow="10" aria-valuemin="0" aria-valuemax="100"></div>
        </div>
    </div>

</div>


<script>

    $("#MainApp").delay(500).fadeIn()

    // ------------------------------ VUE JS ------------------------------ //
    const { createApp } = Vue

    createApp({
        data() {
            return {
                arr_head: ['Yesterday', 'Today', 'Tomorrow', 'This Week', 'Next Week'],
                txt_head: 'Today',
                id_group: '@ViewBag.Data.param_id',
                progressive_bar: '0%',

                count_no_man: 0,
                count_no_mc: 0,
                count_no_mold: 0,
                count_no_met: 0,
                count_no_part: 0,

                time_delay: 1.5,
                time_yesterday: 10,
                time_today: 40,
                time_tomorrow: 20,
                time_thisweek: 15,
                time_nextweek: 20,
                time_total: 0,

                isHide:false,
            }
        },
        async created() {

            const self = this;

            await self.get_yesterday();

            await setTimeout(() => {
                self.get_today();
            }, self.cal_time(self.time_yesterday));

            await setTimeout(() => {
                self.get_tomorrow();
            }, self.cal_time(self.time_today));

            await setTimeout(() => {
                self.get_this_week()
            }, self.cal_time(self.time_tomorrow));

            await setTimeout(() => {
                location.reload();
            }, self.cal_time(self.time_thisweek));

            await $('#MainApp').fadeIn(1500);
        },
        async mounted() {

        },
        methods: {
            progressive(time_show) {
                const self = this;

                self.progressive_bar = '0%'

                let time_sec = 100 / time_show

                for (var i = 0; i <= time_show; i++) {
                    var sno = i + 1;
                    (function myLoop(i) {
                        setTimeout(() => {
                            self.progressive_bar = (i * time_sec) + '%'
                        }, 1000 * i);
                    })(sno);
                }
            },
            cal_time(time_show) {
                const self = this;

                let time = ((time_show * 1000) + (self.time_delay * 1000))

                self.time_total = self.time_total + time;

                return self.time_total;
            },
            addDays(dateTime, count_days = 0) {
                return new Date(new Date(dateTime).setDate(dateTime.getDate() + count_days));
            },
            async get_yesterday() {
                const self = this;

                let today = new Date();

                let d = self.addDays(today, -1)

                let yyyy = d.getFullYear();
                let MM = ('0' + (d.getMonth() + 1)).slice(-2);
                let dd = ('0' + d.getDate()).slice(-2);
                const date_select = dd + "-" + MM + "-" + yyyy;

                self.count_no_man = 0;
                self.count_no_mc = 0;
                self.count_no_mold = 0;
                self.count_no_met = 0;
                self.count_no_part = 0;

                self.txt_head = self.arr_head[0];

                await $.ajax({
                        url: "@Url.Action("Get_Result_Dashboard_Today", "dashboard")",
                        type: "POST",
                    data: { date_select1: date_select, date_select2: date_select, group_id: self.id_group},
                        success: function (result) {
                            if (result.success) {

                                result.data.forEach((item) => {
                                    if (item.TITLE == '1') {
                                        self.count_no_man = item.RESULT
                                    }
                                    if (item.TITLE == '2') {
                                        self.count_no_mc = item.RESULT
                                    }
                                    if (item.TITLE == '3') {
                                        self.count_no_mold = item.RESULT
                                    }
                                    if (item.TITLE == '4') {
                                        self.count_no_met = item.RESULT
                                    }
                                    if (item.TITLE == '5') {
                                        self.count_no_part = item.RESULT
                                    }
                                });


                            }
                        }
                });

                await self.progressive(self.time_yesterday)

            },
            async get_today() {
                const self = this;

                let today = new Date();

                let d = new Date()
                //let d = self.addDays(today, 1)

                let yyyy = d.getFullYear();
                let MM = ('0' + (d.getMonth() + 1)).slice(-2);
                let dd = ('0' + d.getDate()).slice(-2);
                const date_select = dd + "-" + MM + "-" + yyyy;

                self.count_no_man = 0;
                self.count_no_mc = 0;
                self.count_no_mold = 0;
                self.count_no_met = 0;
                self.count_no_part = 0;

                self.txt_head = self.arr_head[1];

                await $.ajax({
                        url: "@Url.Action("Get_Result_Dashboard_Today", "dashboard")",
                        type: "POST",
                    data: { date_select1: date_select, date_select2: date_select, group_id: self.id_group},
                        success: function (result) {
                            if (result.success) {

                                result.data.forEach((item) => {
                                    if (item.TITLE == '1') {
                                        self.count_no_man = item.RESULT
                                    }
                                    if (item.TITLE == '2') {
                                        self.count_no_mc = item.RESULT
                                    }
                                    if (item.TITLE == '3') {
                                        self.count_no_mold = item.RESULT
                                    }
                                    if (item.TITLE == '4') {
                                        self.count_no_met = item.RESULT
                                    }
                                    if (item.TITLE == '5') {
                                        self.count_no_part = item.RESULT
                                    }
                                });


                            }
                        }
                });

                await self.progressive(self.time_today)

            },
            async get_tomorrow() {
                const self = this;

                let today = new Date();

                let d = self.addDays(today, 1)

                let yyyy = d.getFullYear();
                let MM = ('0' + (d.getMonth() + 1)).slice(-2);
                let dd = ('0' + d.getDate()).slice(-2);
                const date_select = dd + "-" + MM + "-" + yyyy;

                self.count_no_man = 0;
                self.count_no_mc = 0;
                self.count_no_mold = 0;
                self.count_no_met = 0;
                self.count_no_part = 0;

                self.txt_head = self.arr_head[2];

                await $.ajax({
                        url: "@Url.Action("Get_Result_Dashboard_Today", "dashboard")",
                        type: "POST",
                    data: { date_select1: date_select, date_select2: date_select, group_id: self.id_group},
                        success: function (result) {
                            if (result.success) {

                                result.data.forEach((item) => {
                                    if (item.TITLE == '1') {
                                        self.count_no_man = item.RESULT
                                    }
                                    if (item.TITLE == '2') {
                                        self.count_no_mc = item.RESULT
                                    }
                                    if (item.TITLE == '3') {
                                        self.count_no_mold = item.RESULT
                                    }
                                    if (item.TITLE == '4') {
                                        self.count_no_met = item.RESULT
                                    }
                                    if (item.TITLE == '5') {
                                        self.count_no_part = item.RESULT
                                    }
                                });


                            }
                        }
                });

                await self.progressive(self.time_tomorrow)

            },
            async get_this_week() {
                const self = this;

                // คำนวณวันที่เริ่มต้นของสัปดาห์
                const today = new Date();
                const weekStart = new Date(today.getFullYear(), today.getMonth(), today.getDate() - today.getDay() );

                // คำนวณวันที่สิ้นสุดของสัปดาห์
                const weekEnd = new Date(weekStart.getFullYear(), weekStart.getMonth(), weekStart.getDate() + 6 - weekStart.getDay());

                // แสดงผล
                //console.log("วันที่เริ่มต้นของสัปดาห์: " + weekStart);
                //console.log("วันที่สิ้นสุดของสัปดาห์: " + weekEnd);

                let yyyy = weekStart.getFullYear();
                let MM = ('0' + (weekStart.getMonth() + 1)).slice(-2);
                let dd = ('0' + weekStart.getDate()).slice(-2);
                const date_select1 = dd + "-" + MM + "-" + yyyy;

                yyyy = weekEnd.getFullYear();
                MM = ('0' + (weekEnd.getMonth() + 1)).slice(-2);
                dd = ('0' + weekEnd.getDate()).slice(-2);
                const date_select2 = dd + "-" + MM + "-" + yyyy;

                self.count_no_man = 0;
                self.count_no_mc = 0;
                self.count_no_mold = 0;
                self.count_no_met = 0;
                self.count_no_part = 0;

                self.txt_head = self.arr_head[3];

                await $.ajax({
                        url: "@Url.Action("Get_Result_Dashboard_Today", "dashboard")",
                        type: "POST",
                        data: { date_select1: date_select1, date_select2: date_select2, group_id: self.id_group},
                        success: function (result) {
                            if (result.success) {

                                result.data.forEach((item) => {
                                    if (item.TITLE == '1') {
                                        self.count_no_man = item.RESULT
                                    }
                                    if (item.TITLE == '2') {
                                        self.count_no_mc = item.RESULT
                                    }
                                    if (item.TITLE == '3') {
                                        self.count_no_mold = item.RESULT
                                    }
                                    if (item.TITLE == '4') {
                                        self.count_no_met = item.RESULT
                                    }
                                    if (item.TITLE == '5') {
                                        self.count_no_part = item.RESULT
                                    }
                                });

                            }
                        }
                });

                await self.progressive(self.time_thisweek)

            },
            async get_next_week() {
                const self = this;

                // คำนวณวันที่เริ่มต้นของสัปดาห์ถัดไป
                const today = new Date();
                const nextWeekStart = new Date(today.getFullYear(), today.getMonth(), today.getDate() + 7 - today.getDay());

                // คำนวณวันที่สิ้นสุดของสัปดาห์ถัดไป
                const nextWeekEnd = new Date(nextWeekStart.getFullYear(), nextWeekStart.getMonth(), nextWeekStart.getDate() + 6 - nextWeekStart.getDay());

                // แสดงผล
                //console.log("วันที่เริ่มต้นของสัปดาห์ถัดไป: " + nextWeekStart);
                //console.log("วันที่สิ้นสุดของสัปดาห์ถัดไป: " + nextWeekEnd);

                let yyyy = nextWeekStart.getFullYear();
                let MM = ('0' + (nextWeekStart.getMonth() + 1)).slice(-2);
                let dd = ('0' + nextWeekStart.getDate()).slice(-2);
                const date_select1 = dd + "-" + MM + "-" + yyyy;

                yyyy = nextWeekEnd.getFullYear();
                MM = ('0' + (nextWeekEnd.getMonth() + 1)).slice(-2);
                dd = ('0' + nextWeekEnd.getDate()).slice(-2);
                const date_select2 = dd + "-" + MM + "-" + yyyy;

                self.count_no_man = 0;
                self.count_no_mc = 0;
                self.count_no_mold = 0;
                self.count_no_met = 0;
                self.count_no_part = 0;

                self.txt_head = self.arr_head[4];

                await $.ajax({
                        url: "@Url.Action("Get_Result_Dashboard_Today", "dashboard")",
                        type: "POST",
                        data: { date_select1: date_select1, date_select2: date_select2, group_id: self.id_group},
                        success: function (result) {
                            if (result.success) {

                                result.data.forEach((item) => {
                                    if (item.TITLE == '1') {
                                        self.count_no_man = item.RESULT
                                    }
                                    if (item.TITLE == '2') {
                                        self.count_no_mc = item.RESULT
                                    }
                                    if (item.TITLE == '3') {
                                        self.count_no_mold = item.RESULT
                                    }
                                    if (item.TITLE == '4') {
                                        self.count_no_met = item.RESULT
                                    }
                                    if (item.TITLE == '5') {
                                        self.count_no_part = item.RESULT
                                    }
                                });


                            }
                        }
                });

                await self.progressive(self.time_nextweek)

            }
        },

        watch: {
        }
    }).mount('#MainApp')


</script>
