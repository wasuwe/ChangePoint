@{
    ViewBag.Title = "Home - Chage Point";
}

<link href="@Html.Raw("https://unpkg.com/filepond@^4/dist/filepond.css")" rel="stylesheet" />
<script src="@Html.Raw("https://unpkg.com/filepond@^4/dist/filepond.js")"></script>


<input type="file" />

<script>
    // Get a reference to the file input element
    const inputElement = document.querySelector('input[type="file"]');

    // Create a FilePond instance
    const pond = FilePond.create(inputElement);
</script>