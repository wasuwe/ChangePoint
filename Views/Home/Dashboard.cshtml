            formatDate(inputDate) {
                const parts = inputDate.split('/');
                const day = parts[0].length === 1 ? `0${parts[0]}` : parts[0];
                const month = parts[1].length === 1 ? `0${parts[1]}` : parts[1];
                const formattedDate = `${month}/${day}/${parts[2]}`;
                return formattedDate;
