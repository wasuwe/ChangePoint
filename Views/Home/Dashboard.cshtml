@{
    ViewBag.Title = "Home";
}

<!-- Add the evo-calendar.css for styling -->
@Styles.Render("~/Content/evo-calendar.min.css")
@Styles.Render("~/Content/bootstrap-select.min.css")

<style>
    /* scrollbar */
    ::-webkit-scrollbar {
        width: 5px;
        height: 5px;
    }

    ::-webkit-scrollbar-track {
        -webkit-box-shadow: inset 0 0 6px rgba(0, 0, 0, 0.3);
        -webkit-border-radius: 10px;
        border-radius: 10px;
    }

    ::-webkit-scrollbar-thumb {
        -webkit-border-radius: 10px;
        border-radius: 10px;
        background: #216583;
        -webkit-box-shadow: inset 0 0 6px rgba(0, 0, 0, 0.5);
    }

        ::-webkit-scrollbar-thumb:window-inactive {
            background: #216583;
        }

    .calendarbox {
        display: flex;
        justify-content: center;
        align-items: center;
        margin-top: 30px;
        z-index: 1;
    }

    /*Man*/
    .event-container > .event-icon > div.event-bullet-man,
    .event-indicator > .type-bullet > div.type-man {
        background-color: #9DE481 !important;
    }

    /*M/C*/
    .event-container > .event-icon > div.event-bullet-mc,
    .event-indicator > .type-bullet > div.type-mc {
        background-color: #D81159 !important;
    }

    /*Mold/DIE*/
    .event-container > .event-icon > div.event-bullet-mold,
    .event-indicator > .type-bullet > div.type-mold {
        background-color: #8A197F !important;
    }

    /*Method*/
    .event-container > .event-icon > div.event-bullet-met,
    .event-indicator > .type-bullet > div.type-met {
        background-color: #91a6ff !important;
    }

    /*Part/Mat'l*/
    .event-container > .event-icon > div.event-bullet-part,
    .event-indicator > .type-bullet > div.type-part {
        background-color: #73D2DE !important;
    }

    .event-indicator {
        width: max-content;
        bottom: -15px;
    }

    .royal-navy .calendar-sidebar > .month-list > .calendar-months {
        padding: 0 15px 0 0;
    }

    .royal-navy .calendar-sidebar {
        background-color: #216583;
        -webkit-box-shadow: 5px 0 18px -3px #216583;
        box-shadow: 5px 0 18px -3px #216583;
    }

        .royal-navy .calendar-sidebar > .month-list > .calendar-months > li.active-month {
            background-color: rgba(0, 0, 0, .35) !important;
        }

        .royal-navy .calendar-sidebar > .month-list > .calendar-months > li:hover {
            background-color: rgba(0, 0, 0, .2) !important;
        }

        .royal-navy .calendar-sidebar > .month-list > .calendar-months > li {
            padding: 9px 30px;
            border-radius: 0 25px 25px 0;
        }

        .royal-navy .calendar-sidebar > span#sidebarToggler {
            width: 35px;
            height: 35px;
            top: 10px;
            right: 0;
            background-color: #f7be16;
            border-radius: 50%;
            padding: 8px;
            -webkit-transform: translate(50%, 0);
            -ms-transform: translate(50%, 0);
            transform: translate(50%, 0);
            -webkit-box-shadow: 0 5px 10px -3px #f7be16;
            box-shadow: 0 5px 10px -3px #f7be16;
            -webkit-transition: all .3s ease;
            -o-transition: all .3s ease;
            transition: all .3s ease;
        }

    .royal-navy button.icon-button > span.bars,
    .royal-navy button.icon-button > span.bars::before,
    .royal-navy button.icon-button > span.bars::after {
        height: 3px;
    }

        .royal-navy button.icon-button > span.bars::before {
            top: -6px;
        }

        .royal-navy button.icon-button > span.bars,
        .royal-navy button.icon-button > span.bars::before,
        .royal-navy button.icon-button > span.bars::after {
            height: 3px;
        }

    .royal-navy th[colspan="7"] {
        color: #216583;
    }

    .royal-navy tr.calendar-body .calendar-day .day.calendar-active,
    .royal-navy tr.calendar-body .calendar-day .day.calendar-active:hover {
        border-color: #164255;
    }

    .royal-navy tr.calendar-body .calendar-day .day:hover {
        background-color: rgba(48, 152, 197, .25);
        color: #164255;
    }

    .royal-navy .calendar-events {
        padding-top: 50px;
        padding-bottom: 40px;
        background-color: #216583;
        color: #fff;
    }

        .royal-navy .calendar-events > .event-header > p {
            text-transform: uppercase;
            padding-bottom: 10px;
            border-bottom: 1px solid #fff;
            color: #fff;
        }

    .royal-navy .event-container:hover > .event-info > p {
        color: #164255;
    }

    .royal-navy .event-container > .event-info > p {
        color: #fff;
    }

    .royal-navy #eventListToggler {
        width: 35px;
        height: 35px;
        top: 10px;
        background-color: #f7be16;
        border-radius: 50%;
        padding: 6px;
        -webkit-box-shadow: 0 5px 10px -3px #f7be16;
        box-shadow: 0 5px 10px -3px #f7be16;
        -webkit-transform: translateX(-10px);
        -ms-transform: translateX(-10px);
        transform: translateX(-10px);
        -webkit-transition: all .3s ease;
        -o-transition: all .3s ease;
        transition: all .3s ease;
    }


    .royal-navy.sidebar-hide .calendar-sidebar > span#sidebarToggler {
        -webkit-transform: translate(calc(100% + 10px), 0);
        -ms-transform: translate(calc(100% + 10px), 0);
        transform: translate(calc(100% + 10px), 0);
        display: flex;
    }

    .royal-navy .calendar-sidebar > span#sidebarToggler {
        width: 35px;
        height: 35px;
        top: 10px;
        right: 0;
        background-color: #f7be16;
        border-radius: 50%;
        padding: 8px;
        -webkit-transform: translate(50%, 0);
        -ms-transform: translate(50%, 0);
        transform: translate(50%, 0);
        -webkit-box-shadow: 0 5px 10px -3px #f7be16;
        box-shadow: 0 5px 10px -3px #f7be16;
        -webkit-transition: all .3s ease;
        -o-transition: all .3s ease;
        transition: all .3s ease;
        display: flex;
    }

    .royal-navy.sidebar-hide .calendar-sidebar {
        -webkit-box-shadow: none;
        box-shadow: none;
    }

    .royal-navy .calendar-sidebar {
        background-color: #216583;
        -webkit-box-shadow: 5px 0 18px -3px #216583;
        box-shadow: 5px 0 18px -3px #216583;
    }

    .royal-navy .event-list > .event-empty {
        background-color: rgba(255, 255, 255, .15);
        border: 1px solid #fff;
    }

        .royal-navy .event-list > .event-empty > p {
            color: #fff;
        }

    .royal-navy .event-container > .event-info > p.event-title > span {
        color: #fff;
        border: 1px solid #164255;
        border-radius: 15px;
        background-color: rgb(22 66 85);
    }

    .btn-addbox {
        display: flex;
        justify-content: flex-end;
        align-items: center;
        margin-top: 30px;
    }


    .col-form-label {
        margin-bottom: 5px;
    }

    .col-form-label {
        display: flex;
        align-content: center;
        align-items: flex-start;
    }

    .modal-header {
        color: #ffffff;
        background-color: #216583;
    }

    .dp__main {
        width: 100%;
    }

    .dropdown.bootstrap-select {
        width: 100% !important;
        border: var(--bs-border-width) solid var(--bs-border-color);
        border-radius: 7px;
    }

    button.btn.dropdown-toggle.btn-light {
        background-color: var(--bs-body-bg);
        background-clip: padding-box;
    }

    .header {
        padding: 15px 0;
        display: flex;
        justify-content: space-between;
        margin-bottom: 30px;
        border-bottom: 5px solid #216583;
    }

    .select-group {
        width: 250px;
        display: flex;
        align-items: center;
        gap: 15px;
    }

    .hint-box {
        display: flex;
        gap: 10px;
    }

    .hint-item {
        display: flex;
        gap: 5px;
        align-items: center;
    }

    .btn-add {
        /* position: absolute;
            right: 20px;
            top: 20px; */
        z-index: 100;
        background: beige;
        padding: 7px 7px;
        border-radius: 8px;
    }

    /* CSS */

    .btn-add {
        width: 0% !important;
        opacity: 0;
        align-items: center;
        background-color: #fff;
        border: 2px solid #000;
        box-sizing: border-box;
        color: #000;
        cursor: pointer;
        display: inline-flex;
        fill: #000;
        font-size: 16px;
        font-weight: 600;
        height: 40px;
        justify-content: center;
        letter-spacing: -.8px;
        line-height: 24px;
        outline: 0;
        padding: 0 0;
        text-align: center;
        text-decoration: none;
        transition: all .3s;
        user-select: none;
        -webkit-user-select: none;
        touch-action: manipulation;
        box-shadow: rgba(0, 0, 0, 0.35) 0px 5px 15px;
    }

        .btn-add .dropdown-toggle {
            overflow: hidden;
        }

        .btn-add.active {
            width: 140px !important;
            opacity: 1;
            z-index: 2;
        }


        .btn-add button {
            align-items: center;
            background-color: unset !important;
            border: unset !important;
            color: #000;
            cursor: pointer;
            display: inline-flex;
            fill: #000;
        }

        .btn-add:focus {
            color: #171e29;
        }

        .btn-add:hover {
            border-color: #06f;
            color: #06f;
            fill: #06f;
        }

        .btn-add:active {
            border-color: #06f;
            color: #06f;
            fill: #06f;
        }

    #MainApp {
        display: none;
    }

    .fileUploads-box {
        position: relative;
    }

        .fileUploads-box .fileUploads {
            margin-bottom: 10px;
            display: flex;
            align-items: center;
            gap: 10px;
        }

            .fileUploads-box .fileUploads input {
                width: 100%;
            }

    .btn-add-file {
        margin-left: 5px;
        cursor: pointer;
        font-size: 25px;
        color: #3fb900;
    }

    .btn-remove-file {
        margin-left: 5px;
        cursor: pointer;
        font-size: 25px;
        color: #cb0000;
    }



    img.image-upload {
        width: 100%;
        height: 50px;
        object-fit: contain;
    }

    .upload-item {
        position: relative;
        text-align: center;
    }

        .upload-item .removeItem {
            border: none;
            background: none;
            color: red;
            font-size: 20px;
            position: absolute;
            right: 0;
            top: 0;
        }

    .upload-boxs {
        margin-top: 25px;
    }

        .upload-boxs p {
            text-overflow: ellipsis;
            overflow: hidden;
            width: 135px;
            height: 1.2em;
            white-space: nowrap;
        }

    .image-gallery {
        display: flex;
        flex-wrap: wrap;
        justify-content: space-between;
    }

        .image-gallery img {
            width: 30%;
            margin-bottom: 10px;
            cursor: pointer;
        }

    .modal {
        display: none;
        position: fixed;
        z-index: 999;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        background-color: rgba(0, 0, 0, 0.8);
    }

    .modal-content {
        max-width: 90%;
        max-height: 90%;
        display: block;
        margin: 0 auto;
        margin-top: 30px;
        z-index: 2;
        object-fit: cover;
    }

    .close {
        color: #fff;
        font-size: 40px;
        position: absolute;
        top: 10px;
        right: 20px;
        cursor: pointer;
    }

    .modal-backdrop {
        z-index: 0 !important;
    }

    .dp__main {
        width: 100%;
    }
</style>

<div id="MainApp">

    <div class="header">


        <div class="select-group">
            <select class="selectpicker" data-placeholder="เลือก Group" data-live-search="true" id="slt_group" name="slt_group" v-model="slt_group" v-on:change="selectGroup(slt_group)">
                <option v-for="(item,index) in groupList" :value="item.GROUP_ID">{{item.GROUP_NAME}}</option>
            </select>
        </div>

        <div class="hint-box">
            <div class="hint-item">
                <i style="color: #9DE481;" class="fas fa-circle"></i>
                Man
            </div>
            <div class="hint-item">
                <i style="color: #D81159;" class="fas fa-circle"></i>
                Machine
            </div>
            <div class="hint-item">
                <i style="color: #8A197F;" class="fas fa-circle"></i>
                Mold/DIE
            </div>
            <div class="hint-item">
                <i style="color: #91a6ff;" class="fas fa-circle"></i>
                Method
            </div>
            <div class="hint-item">
                <i style="color: #73D2DE;" class="fas fa-circle"></i>
                Part/Mat'l
            </div>
        </div>

        @if (ViewBag.Data.ROLE != "V" && ViewBag.Data.ROLE != "G")
        {

            <div class="btn-group btn-add" id="btn-change">
                <button type="button" class=" dropdown-toggle" data-bs-toggle="dropdown" aria-expanded="false">
                    Change Point
                </button>
                <ul class="dropdown-menu">
                    <li id="menu_1">
                        <a class="dropdown-item" onclick="return false;" href="#" v-on:click="Open_Modal('add', '1', '')">Man</a>
                    </li>
                    <li id="menu_2">
                        <a class="dropdown-item" onclick="return false;" href="#" v-on:click="Open_Modal('add', '2', '')">Machine</a>
                    </li>
                    <li id="menu_3">
                        <a class="dropdown-item" onclick="return false;" href="#" v-on:click="Open_Modal('add', '3', '')">Mold/DIE</a>
                    </li>
                    <li id="menu_4">
                        <a class="dropdown-item" onclick="return false;" href="#" v-on:click="Open_Modal('add', '4', '')">Method</a>
                    </li>
                    <li id="menu_5">
                        <a class="dropdown-item" onclick="return false;" href="#" v-on:click="Open_Modal('add', '5', '')">Part/Mat'l</a>
                    </li>
                </ul>
            </div>
        }

    </div>


    <!-- Modal -->
    <div class="modal fade modal-lg" id="change_point_modal" data-bs-backdrop="static" data-bs-keyboard="false" tabindex="-1"
         aria-labelledby="change_point_modal_Label" aria-hidden="true" style="z-index: 2" data-backdrop="static">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title" id="change_point_modal_Label">Change {{title_modal}}</h5>
                </div>
                <div class="    modal-body">

                    <section class="container">
                        <form class="row">

                            <label for="date" class="col-4 col-form-label"><b>วันที่</b></label>
                            <div class="col-8 col-form-label">

                                @if (ViewBag.Data.ROLE != "V" && ViewBag.Data.ROLE != "G")
                                {
                                    <Datepicker v-model="date_select" :enable-time-picker="false" :clearable="false"
                                                :monthChangeOnScroll="false" :format="dateFormat" auto-apply></Datepicker>
                                }
                                else
                                {
                                    <Datepicker v-model="date_select" :enable-time-picker="false" :clearable="false"
                                                :monthChangeOnScroll="false" :format="dateFormat" auto-apply disabled></Datepicker>
                                }

                            </div>

                            <label id="lb_from" for="befor" class="col-4 col-form-label"><b>คนประจำจุด </b></label>
                            <div id="b_from" class="col-8 col-form-label">
                                <div class="input-group" id="">
                                    @if (ViewBag.Data.ROLE != "V" && ViewBag.Data.ROLE != "G")
                                    {
                                        <select class="selectpicker" data-live-search="true" id="slt_spot" v-model="slt_spot">
                                            <option value="">เลือกรายการ</option>
                                            <optgroup v-for="(items, index) in userList" :label="items.wc_code +':'+ items.wc_name">
                                                <option v-for="(item,indexL) in items.list" :value="item.itemId">{{item.itemId}} : {{item.gname_tha}} {{item.fname_tha}} </option>
                                            </optgroup>
                                        </select>
                                    }
                                    else
                                    {
                                        <select class="selectpicker" data-live-search="true" id="slt_spot" v-model="slt_spot" disabled>
                                            <option value="">เลือกรายการ</option>
                                            <optgroup v-for="(items, index) in userList" :label="items.wc_code +':'+ items.wc_name">
                                                <option v-for="(item,indexL) in items.list" :value="item.itemId">{{item.itemId}} : {{item.gname_tha}} {{item.fname_tha}} </option>
                                            </optgroup>
                                        </select>
                                    }

                                </div>
                            </div>

                            <label id="lb_to" for="after" class="col-4 col-form-label"><b>คนแทนจุด</b></label>
                            <div id="b_to" class="col-8 col-form-label">
                                <div class="input-group" id="">

                                    @if (ViewBag.Data.ROLE != "V" && ViewBag.Data.ROLE != "G")
                                    {
                                        <select class="selectpicker " data-live-search="true" id="slt_instead" v-model="slt_instead">
                                            <option value="">เลือกรายการ</option>
                                            <optgroup v-for="(items, index) in userList" :label="items.wc_code +':'+ items.wc_name">
                                                <option v-for="(item,indexL) in items.list" :value="item.itemId">{{item.itemId}} : {{item.gname_tha}} {{item.fname_tha}}</option>
                                            </optgroup>
                                        </select>
                                    }
                                    else
                                    {
                                        <select class="selectpicker " data-live-search="true" id="slt_instead" v-model="slt_instead" disabled>
                                            <option value="">เลือกรายการ</option>
                                            <optgroup v-for="(items, index) in userList" :label="items.wc_code +':'+ items.wc_name">
                                                <option v-for="(item,indexL) in items.list" :value="item.itemId">{{item.itemId}} : {{item.gname_tha}} {{item.fname_tha}}</option>
                                            </optgroup>
                                        </select>
                                    }

                                </div>
                            </div>

                            <label id="lb_mc" for="mc" class="col-4 col-form-label"><b>M/C NO. </b></label>
                            <div id="b_mc" class="col-8 col-form-label">
                                <div class="input-group" id="">

                                    @if (ViewBag.Data.ROLE != "V" && ViewBag.Data.ROLE != "G")
                                    {
                                        <select class="selectpicker " data-live-search="true" id="slt_mc_no" v-model="slt_mc_no">
                                            <option value="">เลือกรายการ</option>
                                            <optgroup v-for="(items, index) in mcsList" :label="items.sizeTon">
                                                <option v-for="(item) in items.list">{{item}} </option>
                                            </optgroup>
                                        </select>
                                    }
                                    else
                                    {
                                        <select class="selectpicker " data-live-search="true" id="slt_mc_no" v-model="slt_mc_no" disabled>
                                            <option value="">เลือกรายการ</option>
                                            <optgroup v-for="(items, index) in mcsList" :label="items.sizeTon">
                                                <option v-for="(item) in items.list">{{item}} </option>
                                            </optgroup>
                                        </select>
                                    }

                                </div>
                            </div>

                            <label id="lb_eidt" for="eidt" class="col-4 col-form-label"><b>จุดที่แก้ไข </b></label>
                            <div id="b_eidt" class="col-8 col-form-label">
                                <div class="input-group" id="">

                                    @if (ViewBag.Data.ROLE != "V" && ViewBag.Data.ROLE != "G")
                                    {
                                        <select class="selectpicker " data-live-search="true" id="slt_edit" v-model="slt_edit">
                                            <option value="">เลือกรายการ</option>
                                            <option v-for="(item) in editList" :value="item.ITEM_NAME">{{item.ITEM_NAME}} </option>
                                        </select>
                                    }
                                    else
                                    {
                                        <select class="selectpicker " data-live-search="true" id="slt_edit" v-model="slt_edit" disabled>
                                            <option value="">เลือกรายการ</option>
                                            <option v-for="(item) in editList" :value="item.ITEM_NAME">{{item.ITEM_NAME}} </option>
                                        </select>
                                    }

                                </div>
                            </div>

                            <label id="lb_part" for="part" class="col-4 col-form-label"><b>Part NO.</b></label>
                            <div id="b_part" class="col-8 col-form-label">
                                <div class="input-group" id="">

                                    @if (ViewBag.Data.ROLE != "V" && ViewBag.Data.ROLE != "G")
                                    {
                                        <select class="selectpicker " data-live-search="true" id="slt_part_no" v-model="slt_part_no">
                                            <option value="">เลือกรายการ</option>
                                            <option v-for="(item) in partsList">{{item.ITEM_ID}} </option>
                                        </select>
                                    }
                                    else
                                    {
                                        <select class="selectpicker " data-live-search="true" id="slt_part_no" v-model="slt_part_no" disabled>
                                            <option value="">เลือกรายการ</option>
                                            <option v-for="(item) in partsList">{{item.ITEM_ID}} </option>
                                        </select>
                                    }

                                </div>
                            </div>


                            <label id="lb_mold" for="mold" class="col-4 col-form-label"><b>Mold NO.</b></label>
                            <div id="b_mold" class="col-8 col-form-label">
                                <div class="input-group" id="">

                                    @if (ViewBag.Data.ROLE != "V" && ViewBag.Data.ROLE != "G")
                                    {
                                        <select class="selectpicker " data-live-search="true" id="slt_mold_no" v-model="slt_mold_no">
                                            <option value="">เลือกรายการ</option>
                                            <option v-for="(item) in moldNOList" :value="item.ITEM_NAME">{{item.ITEM_NAME}} </option>
                                        </select>
                                    }
                                    else
                                    {
                                        <select class="selectpicker " data-live-search="true" id="slt_mold_no" v-model="slt_mold_no" disabled>
                                            <option value="">เลือกรายการ</option>
                                            <option v-for="(item) in moldNOList" :value="item.ITEM_NAME">{{item.ITEM_NAME}} </option>
                                        </select>
                                    }

                                </div>
                            </div>


                            <label id="lb_change" for="mold" class="col-4 col-form-label"><b>หัวข้อการเปลี่ยนแปลง</b></label>
                            <div id="b_change" class="col-8 col-form-label">
                                <div class="input-group" id="">

                                    @if (ViewBag.Data.ROLE != "V" && ViewBag.Data.ROLE != "G")
                                    {
                                        <select class="selectpicker " data-live-search="true" id="slt_change" v-model="slt_change">
                                            <option value="">เลือกรายการ</option>
