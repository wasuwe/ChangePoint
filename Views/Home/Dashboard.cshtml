<script>

    $("#MainApp").delay(500).fadeIn()

    // ------------------------------ VUE JS ------------------------------ //
    const { createApp } = Vue

    createApp({
        data() {
            return {
                date_select: new Date(),
                dateFormat: (date_select) => {
                    const day = date_select.getDate();
                    const month = date_select.getMonth() + 1;
                    const year = date_select.getFullYear();
                    // const hour = date_start.getHours();
                    // const min = date_start.getMinutes();
                    // return `${day}/${month}/${year} ${hour}:${min} `;
                    return `${day}/${month}/${year}`;
                },
                changeType: '',

                eventList: [],

                fileList: [],

                images: [],
                tempID: [],
                fileSize: 0,

                userList: [],
                mcsList: [],
                partsList: [],
                moldNOList: [],
                editList: [],
                changeList: [],
                processList: [],

                changePointList: [],

                manList: [],
                mcList: [],
                moldList: [],
                metList: [],
                partList: [],
                dataList: [],
                dataNameList: [],

                slt_id: '',
                slt_spot: '',
                slt_instead: '',
                slt_mc_no: '',
                slt_edit: '',
                slt_part_no: '',
                slt_mold_no: '',
                slt_change: '',
                slt_process: '',
                slt_detail: '',
                slt_warning: '',

                slt_group: '',

                slt_files: [],
                modal_type: '',
                title_modal: '',
                date_page: '',
                day_page: '',
                month_page: '',
                year_page: '',
                date_calendar: [],

                groupList: [],

                IsAdd:false
            }
        },
        components: { Datepicker: VueDatePicker },
        async created() {

            const self = this;

            setInterval(function(){
                window.location.reload(1);
            }, 300000);

            await self.getGroup()
            await self.getList()

            @if(false)
            {
                //self.eventList = if
                //    {
                //        id: 'bHay68s', // Event's ID (required)
                //        name: "Man (3)", // Event name (required)
                //        date: "08/25/2023", // Event date (required)
                //        type: "man", // Event type (required)
                //        //description: 'Lorem ipsum dolor sit..',
                //        everyYear: false // Same event every year (optional)
                //    },
                //     {
                //         id: 'bHay68saa', // Event's ID (required),
                //         name: "Vacation Leave",
                //         badge: "08/13 - 08/15", // Event badge (optional)
                //         date: ["08/13/2023", "08/15/2023"], // Date range
                //         description: "Vacation leave for 3 days.", // Event description (optional)
                //         type: "event",
                //         color: "#63d867" // Event custom color (optional)
                //     }
                //]
            }



            await $("#evoCalendar").evoCalendar({
            eventHeaderFormat: 'dd MM yyyy',
                theme: 'Royal Navy',
                calendarEvents: self.eventList
            });

            await $('#evoCalendar').on('selectEvent', function (activeEvent) {
                // console.log(activeEvent)
                //console.log(activeEvent.currentTarget.evoCalendar.$active.event_date)

                const date_event = activeEvent.currentTarget.evoCalendar.$active.event_date

                const url = '@Url.Action("detail", "home", new { id = "id_date"})'.replace("id_date", date_event.replaceAll("/", ""));

                window.open(url, '_self')

                @*window.open('@Url.Action("detail", "home")', '_self');*@
            });



            @*self.date_page = '@ViewBag.Data.param_date'

            if (self.date_page) {
                self.day_page = self.date_page.substring(2, 4)
                self.month_page = self.date_page.substring(0, 2)
                self.year_page = self.date_page.substring(4, 9)

                self.date_calendar = new Date(+self.year_page, +self.month_page - 1, +self.day_page);

                self.date_select = self.date_calendar
            }*@

            await self.getMoldNO()
            await self.getProcess()
            await self.getEdit()
            await self.getChange()
            await self.getPart()
            await self.getMC()
            await self.getUser()
            await self.deleteChangePointOver()

            await $('#slt_spot,#slt_instead,#slt_mc_no,#slt_edit,#slt_part_no,#slt_mold_no,#slt_change,#slt_process,#slt_group').selectpicker('destroy');

            await $('select').selectpicker('render');

            await $("#btn-change").addClass('active');

        },
        async mounted() {

        },
        methods: {
            onFileChange(e) {

                var files = e.target.files || e.dataTransfer.files;
                if (!files.length) return;
                this.createImage(files);
            },
           async createImage(files) {
                var self = this;

                let fd;
               let file;

               $("b_file").hide();
               $("#btn-cn").html('<i class="fas fa-sync fa-spin"></i>');
               $("#btn-s").html('<i class="fas fa-sync fa-spin"></i>');

               $("#btn-cn").prop('disabled', true);
               $("#btn-s").prop('disabled', true);

                for (var index = 0; index < files.length; index++) {
                    var reader = new FileReader();

                    self.fileSize += parseFloat(files[index].size) > 0 ? (parseFloat(files[index].size) / (1024 * 1024)) : 0;

                    if (parseFloat(self.fileSize) < 3) {
                        //reader.onload = function (event) {
                        //    const imageUrl = event.target.result;
                        //    self.images.push(imageUrl);
                        //}
                        //reader.readAsDataURL(files[index]);


                        self.fileList.push(files[index]);

                        if ((files[index].type).split("/")[0] === "image") {
                            files[index].file_type = 'image';
                        }

                        if ((files[index].type).split("/")[1] === "pdf") {
                            files[index].file_type = 'pdf';
                        }

                        if ((files[index].type).split("/")[1] === "vnd.openxmlformats-officedocument.spreadsheetml.sheet") {
                            files[index].file_type = 'excel';
                        }

                        if ((files[index].type).split("/")[1] === "vnd.openxmlformats-officedocument.presentationml.presentation") {
                            files[index].file_type = 'powerpoint';
                        }

                        if ((files[index].type).split("/")[1] === "vnd.openxmlformats-officedocument.wordprocessingml.document") {
                            files[index].file_type = 'word';
                        }

                        if ((files[index].type).split("/")[0] === "text") {
                            files[index].file_type = 'text';
                        }

                        fd = new FormData();
                        file = $('#formFileMultiple')[0].files;

                        fd.append('file', file[index]);
                        fd.append('type', file[index].file_type);
                        fd.append('size', ((file[index].size / 1024) / 1024).toFixed(4));
                        fd.append('id', self.slt_id);

                        await $.ajax({
                            url: '@Url.Action("UploadFile", "lookup")',
                            type: 'POST',
                            data: fd,
                            dataType: 'json',
                            contentType: false,
                            processData: false,
                            success: function (response) {
                                self.tempID.push(response.data[0]);
                                self.getFileList(self.slt_id)
                            }
                        });

                    } else {
                        self.fileSize -= parseFloat(files[index].size) > 0 ? (parseFloat(files[index].size) / (1024 * 1024)) : 0;

                        swal({
                            title: "แจ้งเตือน",
                            text: 'ขนาดไฟล์รวมมีขนาดเกิน 3 MB',
                            type: "warning",
                            timer: 2000,
                            showCancelButton: false,
                            showConfirmButton: false
                        })
                    }

                }

               $("b_file").delay(1500).show();
               $("#btn-cn").html('ยกเลิก');
               $("#btn-s").html('บันทึก');

               $("#btn-cn").prop('disabled', false);
               $("#btn-s").prop('disabled', false);

               $("#formFileMultiple").val(null);

            },
            removeImage(index) {
                var self = this;

                fd = new FormData();

                if (self.IsAdd) {
                    fd.append('item_id', self.tempID[index].ITEM_ID);
                    fd.append('item_name', self.tempID[index].ITEM_NAME);
                } else {
                    fd.append('item_id', self.fileList[index].id);
                    fd.append('item_name', self.fileList[index].name);
                }

                $.ajax({
                url: '@Url.Action("deleteFile", "lookup")',
                type: 'POST',
                data: fd,
                    dataType: 'json',
                    contentType: false,
                    processData: false,
                    success: function (response) {}
                });

                this.images.splice(index, 1)
                this.fileList.splice(index, 1)
                this.tempID.splice(index, 1)

            },
            async cancelAdd() {
                var self = this;
                let el = document.querySelector('#change_point_modal');
                let modal = bootstrap.Modal.getOrCreateInstance(el);

                if (self.IsAdd) {

                    for (let i = 0; i < self.fileList.length; i++) {

                        fd = new FormData();
                        fd.append('item_id', self.fileList[i].id);
                        fd.append('item_name', self.fileList[i].name);

                        await $.ajax({
                        url: '@Url.Action("deleteFile", "lookup")',
                        type: 'POST',
                        data: fd,
                            dataType: 'json',
                            contentType: false,
                            processData: false,
                            success: function (response) {}
                        });
                    }


                    fd = new FormData();
                    fd.append('item_id', self.slt_id);

                    await $.ajax({
                        url: '@Url.Action("DeleteItem_ChangePoint", "lookup")',
                        type: 'POST',
                        data: fd,
                            dataType: 'json',
                            contentType: false,
                            processData: false,
                            success: function (response) {}
                        });
                }

                await modal.hide();
            },
            async getFileList(id) {

                const self = this;

                 await $.ajax({
                    url: "@Url.Action("SelectItem_Files", "lookup")",
                    type: "POST",
                     data: { item_id: id },
                    success: function (result) {
                        if (result.success) {

                            self.fileList = []

                            for (let i = 0; i < result.data.length; i++) {
                                self.fileList.push(
                                    {
                                        id: result.data[i].ITEM_ID,
                                        name: result.data[i].ITEM_NAME,
                                        file_type: result.data[i].ITEM_FILE_TYPE,
                                        size: result.data[i].ITEM_FILE_SIZE,
                                    })
                            }

                        }

                    }
                });

            },
             async getProcess() {

                 let self = this;

                 await $.ajax({
                    url: "@Url.Action("Option_Process", "lookup")",
                    type: "POST",
                    data: { },
                    success: function (result) {
                        if (result.success) {
                            self.processList = result.data
                        }

                    }
                 });

            },
            async getMoldNO() {

                 let self = this;

                await $.ajax({
                    url: "@Url.Action("Option_Mold_NO", "lookup")",
                    type: "POST",
                    data: { },
                    success: function (result) {
                        if (result.success) {
                            self.moldNOList = result.data
                        }

                    }
                 });

            },
            async getEdit() {

                 let self = this;

                await $.ajax({
                    url: "@Url.Action("Option_Edit", "lookup")",
                    type: "POST",
                    data: { },
                    success: function (result) {
                        if (result.success) {
                            self.editList = result.data
                        }

                    }
                 });

            },
            async getChange() {

                let self = this;


                await $.ajax({
                    url: "@Url.Action("Option_Change", "lookup")",
                    type: "POST",
                    data: { },
                    success: function (result) {
                        if (result.success) {
                            self.changeList = result.data
                        }

                    }
                 });

            },
            async getPart() {

                 let self = this;

                await $.ajax({
                    url: "@Url.Action("ListItem_Part", "lookup")",
                    type: "POST",
                    data: { },
                    success: function (result) {
                        if (result.success) {
                            self.partsList = result.data
                        }

                    }
                 });

            },
            async getMC() {

                 let self = this;

                await $.ajax({
                    url: "@Url.Action("ListItem_MC", "lookup")",
                    type: "POST",
                    data: { },
                    success: function (result) {
                        if (result.success) {

                            const inputData = result.data

                            const transformedData = {};

                            inputData.forEach(item => {
                                const sizeTon = item.ITEM_SIZETON;
                                const itemId = item.ITEM_NAME;

                                if (sizeTon in transformedData) {
                                    transformedData[sizeTon].list.push(itemId);
                                } else {
                                    transformedData[sizeTon] = {
                                        sizeTon: sizeTon,
                                        list: [itemId]
                                    };
                                }
                            });

                            self.mcsList = Object.values(transformedData);

                        }

                    }
                });
            },
            async getUser() {

                 let self = this;

                await $.ajax({
                    url: "@Url.Action("Option_EMP", "lookup")",
                    type: "POST",
                    data: { },
                    success: function (result) {
                        if (result.success) {

                            const inputData = result.data

                            self.dataNameList = result.data

                            const transformedData = {};

                            inputData.forEach(item => {
                                const itemId = item.EMP_NO;
                                const wc_code = item.WC_CODE;
                                const wc_name = item.WC_NAME;

                                const gname_eng = item.GNAME_ENG;
                                const fname_eng = item.FNAME_ENG;
                                const gname_tha = item.GNAME_TH;
                                const fname_tha = item.FNAME_TH;

                                if (wc_code in transformedData) {
                                    transformedData[wc_code].list.push(
                                        {
                                            itemId: itemId,
                                            gname_eng: gname_eng,
                                            fname_eng: fname_eng,
                                            gname_tha: gname_tha,
                                            fname_tha: fname_tha,
                                        }
                                    );
                                } else {
                                    transformedData[wc_code] = {
                                        wc_code: wc_code,
                                        wc_name: wc_name,
                                        list: [
                                            {
                                                itemId: itemId,
                                                gname_eng: gname_eng,
                                                fname_eng: fname_eng,
                                                gname_tha: gname_tha,
                                                fname_tha: fname_tha,
                                            }
                                        ]
                                    };
                                }
                            });

                            self.userList = Object.values(transformedData);

                        }
                    }
                 });

            },
            async getList() {

                let self = this;

                let d = self.date_select;
                let yyyy = d.getFullYear();
                let MM = ('0' + (d.getMonth() + 1)).slice(-2);
                let dd = ('0' + d.getDate()).slice(-2);
                const date_file = dd + "-" + MM + "-" + yyyy;

                await $.ajax({
                    url: "@Url.Action("ListItem_ChangePoint_All", "lookup")",
                    type: "POST",
                    data: {},
                    success: function (result) {
                        if (result.success) {

                            // สร้างออบเจ็กต์สำหรับการนับ
                            const countByTypeAndDate = {};

                            // วนลูปข้อมูลและนับจำนวน
                            result.data.forEach((item) => {
                                const dateArray = item.DATE_CHANGE.split("/");
                                const dateStr = dateArray[1] + '/' + dateArray[0] + '/' + dateArray[2];
                                const status = item.STATUS_TYPE;

                                // แปลงวันที่จากข้อความเป็น Date object
                                //const dates = new Date(dateStr);
                                const dates = new Date(item.DATE_CHANGE);

                                // สร้างสตริงที่มีรูปแบบ "MM/DD/YYYY"
                                const date = `${(dates.getMonth() + 1).toString().padStart(2, '0')}/${dates.getDate().toString().padStart(2, '0')}/${dates.getFullYear()}`;

                                let type = "";
                                let name = "";
                                switch (status) {
                                    case "1":
                                        type = "man";
                                        name = "Man";
                                        break;
                                    case "2":
                                        type = "mc";
                                        name = "M/C";
                                        break;
                                    case "3":
                                        type = "mold";
                                        name = "Mold/DIE";
                                        break;
                                    case "4":
                                        type = "met";
                                        name = "Method";
                                        break;
                                    case "5":
                                        type = "part";
                                        name = "Part/Mat'l";
                                        break;
                                    default:
                                        type = "unknown";
                                        name = "unknown";
                                }

                                // สร้างออบเจ็กต์สำหรับเก็บข้อมูล
                                const dataObject = {
                                    date,
                                    name,
                                    type,
                                    count: 1, // เริ่มต้นที่ 1
                                };

                                // สร้างคีย์เป็นสตริง "วันที่-TYPE" และเพิ่มข้อมูลลงในออบเจ็กต์
                                const key = `${date}-${type}`;
                                if (countByTypeAndDate[key]) {
                                    countByTypeAndDate[key].count++;
                                    countByTypeAndDate[key].id = type + dates.getDate().toString().padStart(2, '0') + countByTypeAndDate[key].count;
                                    countByTypeAndDate[key].name = name + " (" + countByTypeAndDate[key].count +")";
                                } else {
                                    countByTypeAndDate[key] = dataObject;
                                    countByTypeAndDate[key].id = type + dates.getDate().toString().padStart(2, '0') + countByTypeAndDate[key].count;
                                    countByTypeAndDate[key].name = name + " (1)";
                                }
                            });

                            // แปลงออบเจ็กต์เป็นอาร์เรย์
                            const resultArray = Object.values(countByTypeAndDate);

                            // แสดงผลลัพธ์อาร์เรย์
                            //console.log(resultArray);

                            self.eventList = resultArray

                        }
                    }
                });

