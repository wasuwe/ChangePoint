@{
    ViewBag.Title = "รายการ Change Point";
}

@Styles.Render("~/Content/bootstrap-select.min.css")

@*@Styles.Render("~/Content/select2.min.css")
    @Styles.Render("~/Content/select2-bootstrap-5-theme.min.css")
    @Styles.Render("~/Content/select2-bootstrap-5-theme.rtl.min.css")*@
@Styles.Render("~/Content/vue3-easy-data-table@1.5.47.css")

<style>
        :root {
            --color_man: #9de481;
            --color_mc: #D81159;
            --color_mold: #8A197F;
            --color_met: #91a6ff;
            --color_part: #73D2DE;
        }

    /* scrollbar */
    ::-webkit-scrollbar {
        width: 5px;
        height: 5px;
    }

    ::-webkit-scrollbar-track {
        -webkit-box-shadow: inset 0 0 6px rgba(0, 0, 0, 0.3);
        -webkit-border-radius: 10px;
        border-radius: 10px;
    }

    ::-webkit-scrollbar-thumb {
        -webkit-border-radius: 10px;
        border-radius: 10px;
        background: #216583;
        -webkit-box-shadow: inset 0 0 6px rgba(0, 0, 0, 0.5);
    }

        ::-webkit-scrollbar-thumb:window-inactive {
            background: #216583;
        }



    .btn-add {
        /* position: absolute;
            right: 20px;
            top: 20px; */
        z-index: 100;
        background: beige;
        padding: 7px 7px;
        border-radius: 8px;
    }

        /* CSS */
        .btn-add.active {
            width: 100% !important;
            opacity: 1;
        }

    .btn-add {
        width: 0% !important;
        opacity: 0;
        align-items: center;
        background-color: #fff;
        border: 2px solid #000;
        box-sizing: border-box;
        color: #000;
        cursor: pointer;
        display: inline-flex;
        fill: #000;
        font-size: 16px;
        font-weight: 600;
        height: 40px;
        justify-content: center;
        letter-spacing: -.8px;
        line-height: 24px;
        outline: 0;
        padding: 0 0;
        text-align: center;
        text-decoration: none;
        transition: all .3s;
        user-select: none;
        -webkit-user-select: none;
        touch-action: manipulation;
        box-shadow: rgba(0, 0, 0, 0.35) 0px 5px 15px;
    }

        .btn-add .dropdown-toggle {
            overflow: hidden;
        }


        .btn-add button {
            align-items: center;
            background-color: unset !important;
            border: unset !important;
            color: #000;
            cursor: pointer;
            display: inline-flex;
            fill: #000;
            gap: 5px;
        }

        .btn-add:focus {
            color: #171e29;
        }

        .btn-add:hover {
            border-color: #06f;
            color: #06f;
            fill: #06f;
        }

        .btn-add:active {
            border-color: #06f;
            color: #06f;
            fill: #06f;
        }



    /* CSS */
    .title-box {
        font-size: 16px;
        letter-spacing: 2px;
        text-decoration: none;
        text-transform: uppercase;
        color: #000;
        cursor: pointer;
        border: 3px solid;
        padding: 0.25em 0.5em;
        box-shadow: 1px 1px 0px 0px, 2px 2px 0px 0px, 3px 3px 0px 0px, 4px 4px 0px 0px, 5px 5px 0px 0px;
        position: relative;
        user-select: none;
        -webkit-user-select: none;
        width: 160px;
        text-align: center;
        font-weight: bold;
        margin-bottom: 20px;
    }

        .title-box.title-man {
            box-shadow: var(--color_man) 1px 1px 0px 0px, var(--color_man) 2px 2px 0px 0px, var(--color_man) 3px 3px 0px 0px, var(--color_man) 4px 4px 0px 0px, var(--color_man) 5px 5px 0px 0px;
        }

        .title-box.title-mc {
            box-shadow: var(--color_mc) 1px 1px 0px 0px, var(--color_mc) 2px 2px 0px 0px, var(--color_mc) 3px 3px 0px 0px, var(--color_mc) 4px 4px 0px 0px, var(--color_mc) 5px 5px 0px 0px;
        }

        .title-box.title-mold {
            box-shadow: var(--color_mold) 1px 1px 0px 0px, var(--color_mold) 2px 2px 0px 0px, var(--color_mold) 3px 3px 0px 0px, var(--color_mold) 4px 4px 0px 0px, var(--color_mold) 5px 5px 0px 0px;
        }

        .title-box.title-met {
            box-shadow: var(--color_met) 1px 1px 0px 0px, var(--color_met) 2px 2px 0px 0px, var(--color_met) 3px 3px 0px 0px, var(--color_met) 4px 4px 0px 0px, var(--color_met) 5px 5px 0px 0px;
        }

        .title-box.title-part {
            box-shadow: var(--color_part) 1px 1px 0px 0px, var(--color_part) 2px 2px 0px 0px, var(--color_part) 3px 3px 0px 0px, var(--color_part) 4px 4px 0px 0px, var(--color_part) 5px 5px 0px 0px;
        }

    .table-box {
        box-shadow: rgb(0 0 0 / 35%) 0px 5px 15px;
        border-radius: 8px;
        overflow: hidden;
        padding: 15px;
        margin-bottom: 40px;
    }

    .table {
        margin: 0 !important;
    }


    .col-form-label {
        margin-bottom: 5px;
    }

    .col-form-label {
        display: flex;
        align-content: center;
        align-items: flex-start;
    }

    .modal-header {
        color: #ffffff;
        background-color: #216583;
    }

    img.img-table {
        width: 50px;
        height: auto;
        transition: all 0.8s;
        cursor: pointer;
    }

    /*img.img-table:hover {
            width: 150px;
            height: auto;
            transition: all 0.8s;
        }*/

    /* CSS */
    .image-gallery {
        display: flex;
        flex-wrap: wrap;
        justify-content: space-between;
    }

        .image-gallery img {
            width: 30%;
            margin-bottom: 10px;
            cursor: pointer;
        }

    .modal {
        display: none;
        position: fixed;
        z-index: 999;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        background-color: rgba(0, 0, 0, 0.8);
    }

    .modal-content {
        max-width: 90%;
        max-height: 90%;
        display: block;
        margin: 0 auto;
        margin-top: 30px;
        z-index: 2;
        object-fit: cover;
    }

    .close {
        color: #fff;
        font-size: 40px;
        position: absolute;
        top: 10px;
        right: 20px;
        cursor: pointer;
    }

    .modal-backdrop {
        z-index: 0 !important;
    }

    .dp__main {
        width: 100%;
    }

    .dropdown.bootstrap-select {
        width: 100% !important;
        border: var(--bs-border-width) solid var(--bs-border-color);
        border-radius: 7px;
    }

    button.btn.dropdown-toggle.btn-light {
        background-color: var(--bs-body-bg);
        background-clip: padding-box;
    }

    .no-data-box {
        box-shadow: rgb(0 0 0 / 31%) 0px 5px 15px;
        border-radius: 8px;
        overflow: hidden;
        padding: 15px;
        margin-bottom: 40px;
        text-align: center;
        font-weight: bold;
        font-size: 20px;
    }

    #MainApp {
        display: none;
    }

    .fileUploads-box {
        position: relative;
    }

        .fileUploads-box .fileUploads {
            margin-bottom: 10px;
            display: flex;
            align-items: center;
            gap: 10px;
        }

            .fileUploads-box .fileUploads input {
                width: 100%;
            }

    .btn-add-file {
        margin-left: 5px;
        cursor: pointer;
        font-size: 25px;
        color: #3fb900;
    }

    .btn-remove-file {
        margin-left: 5px;
        cursor: pointer;
        font-size: 25px;
        color: #cb0000;
    }

    img.image-upload {
        width: 100%;
        height: 50px;
        object-fit: contain;
    }

    .upload-item {
        position: relative;
        text-align: center;
    }

        .upload-item .removeItem {
            border: none;
            background: none;
            color: red;
            font-size: 20px;
            position: absolute;
            right: 0;
            top: 0;
        }

    .upload-boxs {
        margin-top: 25px;
    }

        .upload-boxs p {
            text-overflow: ellipsis;
            overflow: hidden;
            width: 135px;
            height: 1.2em;
            white-space: nowrap;
        }

         .section-to-print {
        visibility: hidden;
        margin-bottom: 15px;
    }

    .header-box {
        margin-top: 15px;
        margin-bottom: 20px;
        border-bottom: 5px solid #216583;
    }

    .header-box .row > div {
        margin-bottom: 10px;
    }


    .tooltip-name {
        font-size: 13px;
        font-weight: bold;
    }

    .tooltip-date {
    }

    .tooltip-inner {
    }


    .select2-selection__rendered {
        display: flex;
        flex-direction: column !important;
    }

    @Html.Raw("@media print")  {
        body * {
            visibility: hidden;
            height:0;
            margin:0;
                font-size: 14px !important;
        }

       @Html.Raw("@page") {
           size: A4  landscape;
           }

        .section-to-print, .section-to-print * {
           visibility: visible;
           height:auto;
           }
        .section-to-print-hide {
           display: none;
           }
       }


    .customize-table {
        --easy-table-header-font-size: 14px;
        --easy-table-header-height: 50px;
        --easy-table-header-font-color: #ffffff;
        --easy-table-header-background-color: #2d3a4f;
        --easy-table-border: 1px solid #445269;
    }

    .recipient-box {
        margin-bottom: 15px;
    }

    .name-list {
        border: 1px solid #999999;
        padding: 5px 10px;
        border-bottom-right-radius: 8px;
        border-bottom-left-radius: 8px;
        font-size: 18px;
    }

    .head-recipient {
        text-align: center;
        font-size: 35px;
        font-weight: bold;
        text-decoration: none;
        border: 1px solid #999999;
        border-top-right-radius: 8px;
        border-top-left-radius: 8px;
        padding: 5px 5px;
    }

    .head-recipient a {
        text-decoration: none;
    }
    #print-area td {
        table-layout: fixed;
        width: 100%
    }
    #print-area {
        font-family: monospace;
    }
    #print-area td {
    }

    #print-area tr,
    #print-area th,
    #print-area td {
        border: 1px solid;

    }

    #print-area thead {
        font-size: 13px;
    }

    #print-area tbody {
        font-size: 10px;
    }

    .box-title {
        position: relative;
        display: flex;
        flex-direction: column;
    }

    /* ── Modern overrides ── */
    :root {
        --color_man:  #22c55e;
        --color_mc:   #ef4444;
        --color_mold: #a855f7;
        --color_met:  #3b82f6;
        --color_part: #06b6d4;
    }

    #MainApp { display: none; }

    /* Header toolbar */
    .header-box {
        background: #fff;
        border-radius: 14px;
        box-shadow: 0 2px 12px rgba(0,0,0,.07);
        padding: 16px 20px;
        margin-bottom: 20px;
        border-bottom: none !important;
    }

    /* Section title bars */
    .title-box {
        display: flex;
        align-items: center;
        gap: 10px;
        padding: 10px 18px;
        border-radius: 10px;
        font-size: .9rem;
        letter-spacing: .05em;
        font-weight: 700;
        text-transform: uppercase;
        color: #fff;
        width: auto;
        box-shadow: none !important;
        border: none !important;
        margin-bottom: 12px;
    }
    .title-box.title-man  { background: var(--color_man);  }
    .title-box.title-mc   { background: var(--color_mc);   }
    .title-box.title-mold { background: var(--color_mold); }
    .title-box.title-met  { background: var(--color_met);  }
    .title-box.title-part { background: var(--color_part); }

    /* Section table cards */
    .table-box {
        background: #fff;
        border-radius: 12px;
        box-shadow: 0 2px 12px rgba(0,0,0,.07);
        padding: 0;
        overflow: hidden;
        margin-bottom: 24px;
    }

    /* Add CP button */
    .btn-add {
        width: auto !important;
        opacity: 0;
        background: #3b82f6 !important;
        border: none !important;
        border-radius: 9px !important;
        color: #fff !important;
        fill: #fff !important;
        box-shadow: 0 2px 8px rgba(59,130,246,.35) !important;
        padding: 0 18px !important;
        height: 38px !important;
        font-size: .88rem !important;
        transition: opacity .4s, background .15s !important;
    }
    .btn-add.active { opacity: 1 !important; }
    .btn-add button { color: #fff !important; fill: #fff !important; }
    .btn-add:hover { background: #2563eb !important; border-color: transparent !important; color: #fff !important; }

    /* Modal header */
    .modal-header {
        background: #1e293b !important;
        color: #fff !important;
        border-bottom: none !important;
    }

    /* No data */
    .no-data-box {
        background: #fff;
        border-radius: 12px;
        box-shadow: 0 2px 12px rgba(0,0,0,.07);
        padding: 40px 20px;
        text-align: center;
        color: #94a3b8;
        font-size: 1rem;
        margin-bottom: 20px;
    }
    .no-data-box i { font-size: 2.5rem; margin-bottom: 12px; display: block; }

    /* Recipient boxes */
    .head-recipient {
        background: #f8fafc;
        border: 1px solid #e2e8f0 !important;
        border-radius: 10px 10px 0 0 !important;
        font-size: 1.1rem !important;
        font-weight: 700 !important;
        color: #1e293b;
        padding: 10px 16px !important;
    }
    .name-list {
        border: 1px solid #e2e8f0 !important;
        border-top: none !important;
        border-radius: 0 0 10px 10px !important;
        font-size: .9rem !important;
        padding: 8px 16px !important;
    }

    .inspector-chip-sm {
        display: inline-flex; align-items: center; gap: 5px;
        background: #f1f5f9; border: 1px solid #e2e8f0;
        border-radius: 6px; padding: 3px 9px;
        font-size: .78rem; margin: 2px;
    }

    .dp__main { width: 100%; }

    img.image-upload { width:100%;height:50px;object-fit:contain; }
    .upload-item { position:relative;text-align:center; }
    .upload-item .removeItem { border:none;background:none;color:red;font-size:18px;position:absolute;right:0;top:0; }
    .upload-boxs { margin-top:16px; }
    .upload-boxs p { text-overflow:ellipsis;overflow:hidden;width:120px;height:1.2em;white-space:nowrap;font-size:.72rem; }

    .form-label-cp { font-size:.8rem;font-weight:600;color:#475569;margin-bottom:4px;display:block; }
    .form-label-cp .th { font-weight:400;color:#94a3b8;font-size:.74rem;margin-left:4px; }
    .detail-wrap { border:1px solid #e2e8f0;border-radius:8px;overflow:hidden;margin-top:8px; }
    .detail-wrap table { margin:0;font-size:.8rem; }
    .detail-wrap thead th { background:#f8fafc;font-weight:600;font-size:.75rem; }
    .inspector-chip { display:inline-flex;align-items:center;gap:6px;background:#f1f5f9;border:1px solid #e2e8f0;border-radius:6px;padding:4px 10px;font-size:.78rem;margin:3px 3px 3px 0; }
    .modal-backdrop { z-index:0 !important; }

    #imgLightbox { display:none;position:fixed;z-index:9999;top:0;left:0;width:100%;height:100%;background:rgba(0,0,0,.85);align-items:center;justify-content:center; }
    #imgLightbox.open { display:flex; }
    #imgLightbox img { max-width:90vw;max-height:85vh;border-radius:8px; }
    #imgLightbox .lb-close { position:absolute;top:16px;right:20px;color:#fff;font-size:2rem;cursor:pointer; }

    .section-to-print { visibility:hidden; margin-bottom:15px; }
    @Html.Raw("@media print") {
        body * { visibility:hidden;height:0;margin:0;font-size:14px !important; }
        @Html.Raw("@page") { size:A4 landscape; }
        .section-to-print, .section-to-print * { visibility:visible;height:auto; }
        .section-to-print-hide { display:none; }
    }
</style>
<div id="imgLightbox"><span class="lb-close" onclick="document.getElementById('imgLightbox').classList.remove('open')">&times;</span><img id="lbImg" src="" alt="" /></div>

<div class="container-fluid " id="MainApp">
    <!-- Add more images as needed -->
    <div class="modal">
        <span class="close" onclick="closeModal()">&times;</span>
        <img class="modal-content" alt="Modal Image">
    </div>

    <div class="header-box section-to-print-hide gap-2">

        <div class="row">
            <div class="col-md-8">
                <div class="date-box" style="font-weight: bold;">

                    <div class="row">
                        <div class="col-md-3">
                            <div class="date " id="datepicker11">
                                <Datepicker v-model="date_select" :enable-time-picker="false" :clearable="false"
                                            :monthChangeOnScroll="false" :format="dateFormat" auto-apply :markers="markers"></Datepicker>
                            </div>
                        </div>

                        <div class="col-md-3">
                            <div class="select-group">
                                <select class="selectpicker" data-placeholder="เลือก Group" data-live-search="true" id="slt_group" name="slt_group" v-model="slt_group">
                                    <option v-for="(item,index) in groupList" :value="item.GROUP_ID">{{item.GROUP_NAME}}</option>
                                </select>
                            </div>
                        </div>

                        <div class="col-md-3">
                            <div class="btn-date d-grid">
                                <a name="" id="" class="btn btn-primary" href="#" role="button" onclick="return false;" v-on:click="searchDate"> <i class="fas fa-search"></i> ค้นหา</a>
                            </div>
                        </div>

                        <div class="col-md-3" v-if="manList.length > 0 || mcList.length > 0 || moldList.length > 0 || metList.length > 0 || partList.length > 0">
                            <div class="btn-date d-grid">
                                <a name="" id="" class="btn btn-success" href="#" role="button" onclick="return false;" v-on:click="open_modal_print()">
                                    <i class="fas fa-print"></i> ปริ้น
                                </a>
                            </div>
                        </div>
                    </div>

                </div>
            </div>

            <div class="col-md-3 offset-md-1">
                @if (ViewBag.Data.ROLE != "V" && ViewBag.Data.ROLE != "G")
                {
                    <div class="btn-group btn-add " id="btn-change">
                        <button type="button" class=" dropdown-toggle" data-bs-toggle="dropdown" aria-expanded="false">
                            <i class="fas fa-plus-circle"></i> Change Point
                        </button>
                        <ul class="dropdown-menu">
                            <li id="menu_1">
                                <a class="dropdown-item" onclick="return false;" href="#" v-on:click="Open_Modal('add', '1', '')">Man</a>
                            </li>
                            <li id="menu_2">
                                <a class="dropdown-item" onclick="return false;" href="#" v-on:click="Open_Modal('add', '2', '')">Machine</a>
                            </li>
                            <li id="menu_3">
                                <a class="dropdown-item" onclick="return false;" href="#" v-on:click="Open_Modal('add', '3', '')">Mold/DIE</a>
                            </li>
                            <li id="menu_4">
                                <a class="dropdown-item" onclick="return false;" href="#" v-on:click="Open_Modal('add', '4', '')">Method</a>
                            </li>
                            <li id="menu_5">
                                <a class="dropdown-item" onclick="return false;" href="#" v-on:click="Open_Modal('add', '5', '')">Part/Mat'l</a>
                            </li>
                        </ul>
                    </div>
                }
            </div>

        </div>


    </div>

    <div class="body-content section-to-print-hide" id="">

        <div class="no-data-box" v-if="manList.length==0&&mcList.length==0&&moldList.length==0&&metList.length==0&&partList.length==0">
            <i class="fas fa-calendar-times"></i>
            ไม่พบ Change Point ในวันนี้
        </div>

        <div class="title-box title-man" v-if="manList.length > 0">Man</div>

        <div class="table-box table-man" v-if="manList.length > 0">
            <div class="table-responsive">

                <easy-data-table :headers="headers_man"
                                 :items="items_man"
                                 :sort-by="sortBy_man"
                                 :sort-type="sortType_man"
                                 table-class-name="customize-table"
                                 multi-sort
                                 show-index
                                 border-cell
                                 class="text-center"
                                 header-text-direction="center"
                                 body-text-direction="center" />

                <template #item-shift="{ shift, team }">
                    {{shift == 1 ? 'Day' : 'Night'}} ({{team}})
                </template>

                <template #item-create_date="{ create_date, create_by }">
                    {{create_date}}
                    <br /> {{create_by}}
                </template>

                <template #item-update_date="{ update_date, update_by }">
                    {{update_date}}
                    <br /> {{update_by}}
                </template>

                <template #item-informed="{ informed, id, recipient_ids }">
                    <i v-if="informed ==  'N'" style="font-size:25px; color:#328cd9; cursor: pointer;" class="fas fa-exclamation-circle" v-on:click="open_modal_recipient(recipient_ids, id)"></i>
                    <i v-else="" style="font-size:25px; color:#25c331; cursor: pointer;" class="fas fa-check" v-on:click="open_modal_recipient(recipient_ids, id)"></i>
                </template>

                <template #item-man_spot_name_tha="{ man_spot_name_tha, id }">
                    <a class="link-primary" href="#" onclick="return false;" v-on:click="Open_Modal('edit','1',id)">
                        {{man_spot_name_tha}}
                    </a>
                </template>

                <template #item-action="{ action }">
                    <ul>
                        <li v-for="(item, index) in action" style="list-style-type: none;">{{index+1}}. {{item}}</li>
                    </ul>
                </template>

                <template #item-warnings="{ warnings }">
                    <ul>
                        <li v-for="(item, index) in warnings" style="list-style-type: none;">{{index+1}}. {{item}}</li>
                    </ul>
                </template>

            </div>


        </div>

        <div class="title-box title-mc" v-if="mcList.length > 0">M/C</div>

        <div class="table-box table-mc" v-if="mcList.length > 0">
            <div class="table-responsive">
                <easy-data-table :headers="headers_mc"
                                 :items="items_mc"
                                 :sort-by="sortBy_mc"
                                 :sort-type="sortType_mc"
                                 table-class-name="customize-table"
                                 multi-sort
                                 show-index
                                 border-cell
                                 class="text-center"
                                 header-text-direction="center"
                                 body-text-direction="center" />

