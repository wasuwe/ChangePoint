            async Save_Data() {

                const self = this
                let el = document.querySelector('#change_point_modal');
                let modal = bootstrap.Modal.getOrCreateInstance(el);

                let file_name = '';
                let file_size = 0;
                let file_type;
                let check_input = true;

                if (
                    self.slt_shift == '' ||
                    self.slt_team == '' ||
                    self.slt_detail.length == 0 ||
                    self.slt_warning.length == 0 ||
                    self.slt_recipient.length == 0
                   )
                {
                    check_input = false;
                }


                switch (self.modal_type) {
                    case '1':
                        if (
                            self.slt_instead == '' || self.slt_spot == '' || self.slt_mc_no == '' || self.slt_process == '') {
                            check_input = false;
                        }
                        break;
                    case '2':
                        if (
                            self.slt_mc_no == '' || self.slt_edit == '') {
                            check_input = false;
                        }
                        break;
                    case '3':
                        if (
                            self.slt_part_no == '' || self.slt_mold_no == '') {
                            check_input = false;
                        }
                        break;
                    case '4':
                        if (
                            self.slt_part_no == '' || self.slt_mc_no == '') {
                            check_input = false;
                        }
                        break;
                    case '5':
                        if (
                            self.slt_part_no == '' || self.slt_mc_no == '' || self.slt_change == '') {
                            check_input = false;
                        }
                        break;
                }


                if (!check_input) {

                    alertBoxTime('Alert', 'Please fill out the information completely', 'warning', 1100, '', '')

                } else {

                    let spot_name_eng = ''
                    let spot_name_tha = ''
                    let instead_name_eng = ''
