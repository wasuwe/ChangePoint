                let modal = await bootstrap.Modal.getOrCreateInstance(el);

                await $('#print-area').show();

                // แทน elementId ด้วย ID ของ element ที่คุณต้องการสร้าง PDF
                const elementId = 'print-area';
                const element = document.getElementById(elementId);

                // กำหนดตัวเลือก (options) ตามที่คุณต้องการ
                const options = {
                    margin: [10, 5, 10, 5],
                    pagebreak: { avoid: ['tr'] } ,
                    filename: 'document.pdf',
                    image: { type: 'jpeg', quality: 0.98 },
                    html2canvas: { scale: 2 },
                    jsPDF: {
                        orientation: 'l',
                        unit: 'mm',
                        format: 'a4',
                        putOnlyUsedFonts: false,
                        floatPrecision: 16
                    }
                };
                                                          
                // New Promise-based usage:
                await html2pdf().set(options).from(element).toPdf().get('pdf').then(function (pdf) {
                    window.open(pdf.output('bloburl'), '_blank');
                });

                await $('#print-area').hide();

                await modal.hide()
            },
