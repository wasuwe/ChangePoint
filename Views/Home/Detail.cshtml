            Datepicker: VueDatePicker,
            EasyDataTable: window['vue3-easy-data-table'],
        },
        async created() {

            const self = this;

            await self.getGroup();

            self.date_page = '@ViewBag.Data.param_date'

            if (self.date_page) {
                self.day_page = self.date_page.substring(2, 4)
                self.month_page = self.date_page.substring(0, 2)
                self.year_page = self.date_page.substring(4, 9)

                self.date_calendar = new Date(+self.year_page, +self.month_page - 1, +self.day_page);

                self.date_select = self.date_calendar
            }

            await self.getList()
            await self.getList_calendar()

            await self.getMoldNO()
            await self.getProcess()
            await self.getEdit()
            await self.getChange()
            await self.getPart()
            await self.getMC()
            await self.getUser()

            await self.get_recipient_option()


            let d = self.date_select;
            let yyyy = d.getFullYear();
            let MM = ('0' + (d.getMonth() + 1)).slice(-2);
            let dd = ('0' + d.getDate()).slice(-2);
            self.date_print = dd + "-" + MM + "-" + yyyy;


            let tooltipelements = document.querySelectorAll("[data-bs-toggle='tooltip']");
            tooltipelements.forEach((el) => {
                new bootstrap.Tooltip(el);
            });

            await self.get_colors()

            await $('#slt_spot,#slt_instead,#slt_mc_no,#slt_edit,#slt_part_no,#slt_mold_no,#slt_change,#slt_process, #slt_recipient').selectpicker('destroy');

            await $('#slt_spot,#slt_instead,#slt_mc_no,#slt_edit,#slt_part_no,#slt_mold_no,#slt_change,#slt_process, #slt_recipient').selectpicker('render');
            await $("#btn-change").addClass('active');




        },
        mounted() {
            this.root = document.documentElement;
        },
        watch: {

        },
        methods: {
            async set_risk() {

                const self = this;

                self.slt_action = await []
                self.slt_warning = await []

                await  self.slt_detail.forEach((v, i) => {
                    index = self.details_list.findIndex(item => item.ITEM_ID === v);
                    self.slt_action.push(self.details_list[index].ITEM_DETAIL)
                    self.slt_warning.push(self.details_list[index].ITEM_RISK)
                })

            },
            async set_recipient() {

                const self = this;

                self.recipient_list = await []

                await self.slt_recipient.forEach((v, i) => {
                    index = self.recipient_option.findIndex(item => item.ITEM_ID === v);
                    self.recipient_list.push(self.recipient_option[index])
                })

                await console.log(self.recipient_list)

            },
            onFileChange(e) {

                var files = e.target.files || e.dataTransfer.files;
                if (!files.length) return;
                this.createImage(files);
            },
           async createImage(files) {
                var self = this;

                let fd;
               let file;

               $("b_file").hide();
               $("#btn-cn").html('<i class="fas fa-sync fa-spin"></i>');
               $("#btn-s").html('<i class="fas fa-sync fa-spin"></i>');

               $("#btn-cn").prop('disabled', true);
               $("#btn-s").prop('disabled', true);

                for (var index = 0; index < files.length; index++) {
                    var reader = new FileReader();

                    self.fileSize += parseFloat(files[index].size) > 0 ? (parseFloat(files[index].size) / (1024 * 1024)) : 0;

                    if (parseFloat(self.fileSize) < 3) {
                        //reader.onload = function (event) {
                        //    const imageUrl = event.target.result;
                        //    self.images.push(imageUrl);
                        //}
                        //reader.readAsDataURL(files[index]);


                        self.fileList.push(files[index]);

                        if ((files[index].type).split("/")[0] === "image") {
                            files[index].file_type = 'image';
                        }

                        if ((files[index].type).split("/")[1] === "pdf") {
                            files[index].file_type = 'pdf';
                        }

                        if ((files[index].type).split("/")[1] === "vnd.openxmlformats-officedocument.spreadsheetml.sheet") {
                            files[index].file_type = 'excel';
                        }

                        if ((files[index].type).split("/")[1] === "vnd.openxmlformats-officedocument.presentationml.presentation") {
                            files[index].file_type = 'powerpoint';
                        }

                        if ((files[index].type).split("/")[1] === "vnd.openxmlformats-officedocument.wordprocessingml.document") {
                            files[index].file_type = 'word';
                        }

                        if ((files[index].type).split("/")[0] === "text") {
                            files[index].file_type = 'text';
                        }

                        fd = new FormData();
                        file = $('#formFileMultiple')[0].files;

                        fd.append('file', file[index]);
                        fd.append('type', file[index].file_type);
                        fd.append('size', ((file[index].size / 1024) / 1024).toFixed(4));
                        fd.append('id', self.slt_id);

                        await $.ajax({
                            url: '@Url.Action("UploadFile", "lookup")',
                            type: 'POST',
                            data: fd,
                            dataType: 'json',
                            contentType: false,
                            processData: false,
                            success: async function (response) {
                                await self.tempID.push(response.data[0]);
                                await self.file_ids.push(response.data[0].ITEM_ID)
                                await self.getFileList(response.data[0])
                            }
                        });

                    } else {
                        self.fileSize -= parseFloat(files[index].size) > 0 ? (parseFloat(files[index].size) / (1024 * 1024)) : 0;

                        swal({
                            title: "Alert",
                            text: 'ขนาดไฟล์รวมมีขนาดเกิน 3 MB',
                            type: "warning",
                            timer: 2000,
                            showCancelButton: false,
                            showConfirmButton: false
                        })
                    }

                }

               $("b_file").delay(1500).show();
               $("#btn-cn").html('Cancel');
               $("#btn-s").html('Save');

               $("#btn-cn").prop('disabled', false);
               $("#btn-s").prop('disabled', false);

               $("#formFileMultiple").val(null);

