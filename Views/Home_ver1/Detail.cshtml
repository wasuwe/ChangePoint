<script>

    $("#MainApp").delay(500).fadeIn()

    // ------------------------------ VUE JS ------------------------------ //
    const { createApp } = Vue

    createApp({
        data() {
            return {
                date_select: new Date(),
                dateFormat: (date_select) => {
                    const day = date_select.getDate();
                    const month = date_select.getMonth() + 1;
                    const year = date_select.getFullYear();
                    // const hour = date_start.getHours();
                    // const min = date_start.getMinutes();
                    // return `${day}/${month}/${year} ${hour}:${min} `;
                    return `${day}/${month}/${year}`;
                },
                changeType: '',

                fileList: [],

                images: [],
                tempID: [],
                fileSize: 0,

                userList: [],
                mcsList: [],
                partsList: [],
                moldNOList: [],
                editList: [],
                changeList: [],
                processList: [],

                changePointList: [],

                manList: [],
                mcList: [],
                moldList: [],
                metList: [],
                partList: [],
                dataList: [],
                dataNameList: [],

                slt_id: '',
                slt_spot: '',
                slt_instead: '',
                slt_mc_no: '',
                slt_edit: '',
                slt_part_no: '',
                slt_mold_no: '',
                slt_change: '',
                slt_process: '',
                slt_detail: '',
                slt_warning: '',
                slt_group: '',

                date_print: '',

                slt_files: [],
                modal_type: '',
                title_modal: '',
                date_page: '',
                day_page: '',
                month_page: '',
                year_page: '',
                date_calendar: [],
                groupList: [],

                IsAdd: false,

                performanceList: {},
            }
        },
        components: { Datepicker: VueDatePicker },
        async created() {

            const self = this;

            self.performanceList = {
                0: {'performance': 'Multi','scale':'75%'},
                1: {'performance': 'Support','scale':'75%'},
                2: {'performance': 'Multi','scale':'100%'}
            }

            await self.getGroup();

            self.date_page = '@ViewBag.Data.param_date'

            if (self.date_page) {
                self.day_page = self.date_page.substring(2, 4)
                self.month_page = self.date_page.substring(0, 2)
                self.year_page = self.date_page.substring(4, 9)

                self.date_calendar = new Date(+self.year_page, +self.month_page - 1, +self.day_page);

                self.date_select = self.date_calendar
            }

            await self.getList()

            await self.getMoldNO()
            await self.getProcess()
            await self.getEdit()
            await self.getChange()
            await self.getPart()
            await self.getMC()
            await self.getUser()


            await $('#slt_spot,#slt_instead,#slt_mc_no,#slt_edit,#slt_part_no,#slt_mold_no,#slt_change,#slt_process,#slt_group').selectpicker('destroy');

            await $('select').selectpicker('render');
            await $("#btn-change").addClass('active');

            //imageContainer = document.createElement("figure");
            //img = document.createElement("img");
            //imageDisplay = document.getElementById("image-display");

            //img.src = '/src/icons/pdf.png'
            //imageContainer.appendChild(img);

            //imageContainer.innerHTML += `<figcaption>xxx.xxx</figcaption>`;
            //imageDisplay.appendChild(imageContainer);


            let d = self.date_select;
            let yyyy = d.getFullYear();
            let MM = ('0' + (d.getMonth() + 1)).slice(-2);
            let dd = ('0' + d.getDate()).slice(-2);
            self.date_print = dd + "-" + MM + "-" + yyyy;


        },
        mounted() {
            const self = this;

        },
        methods: {
            onFileChange(e) {

                var files = e.target.files || e.dataTransfer.files;
                if (!files.length) return;
                this.createImage(files);
            },
           async createImage(files) {
                var self = this;

                let fd;
               let file;

               $("b_file").hide();
               $("#btn-cn").html('<i class="fas fa-sync fa-spin"></i>');
               $("#btn-s").html('<i class="fas fa-sync fa-spin"></i>');

               $("#btn-cn").prop('disabled', true);
               $("#btn-s").prop('disabled', true);

                for (var index = 0; index < files.length; index++) {
                    var reader = new FileReader();

