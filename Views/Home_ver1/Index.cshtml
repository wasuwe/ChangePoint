@{
    ViewBag.Title = "ปฏิทิน Change Point";
}

@Styles.Render("~/Content/bootstrap-select.min.css")

<style>
:root {
    --color_man:  #22c55e;
    --color_mc:   #ef4444;
    --color_mold: #a855f7;
    --color_met:  #3b82f6;
    --color_part: #06b6d4;
}

#MainApp { display: none; }

.cal-toolbar { display:flex;align-items:center;gap:10px;flex-wrap:wrap;margin-bottom:16px; }
.group-select { min-width:180px; }

.stats-row { display:flex;gap:8px;flex-wrap:wrap;margin-bottom:16px; }
.stat-chip { display:flex;align-items:center;gap:6px;padding:6px 14px;border-radius:20px;font-size:.82rem;font-weight:600; }
.stat-chip .sd { width:10px;height:10px;border-radius:50%;flex-shrink:0; }
.chip-man  { background:color-mix(in srgb,var(--color_man)  12%,white); color:color-mix(in srgb,var(--color_man)  60%,#111); }
.chip-mc   { background:color-mix(in srgb,var(--color_mc)   12%,white); color:color-mix(in srgb,var(--color_mc)   60%,#111); }
.chip-mold { background:color-mix(in srgb,var(--color_mold) 12%,white); color:color-mix(in srgb,var(--color_mold) 60%,#111); }
.chip-met  { background:color-mix(in srgb,var(--color_met)  12%,white); color:color-mix(in srgb,var(--color_met)  60%,#111); }
.chip-part { background:color-mix(in srgb,var(--color_part) 12%,white); color:color-mix(in srgb,var(--color_part) 60%,#111); }
.sd-man  { background:var(--color_man); }
.sd-mc   { background:var(--color_mc); }
.sd-mold { background:var(--color_mold); }
.sd-met  { background:var(--color_met); }
.sd-part { background:var(--color_part); }

.cal-card { background:#fff;border-radius:16px;box-shadow:0 2px 16px rgba(0,0,0,.08);overflow:hidden; }
.cal-head { display:flex;align-items:center;justify-content:space-between;padding:16px 20px;border-bottom:1px solid #e2e8f0;background:#f8fafc; }
.cal-month-label { font-size:1.15rem;font-weight:700;color:#1e293b; }
.cal-nav-btns { display:flex;align-items:center;gap:6px; }
.cal-nav-btn { width:34px;height:34px;border-radius:8px;border:1px solid #e2e8f0;background:#fff;color:#475569;cursor:pointer;display:flex;align-items:center;justify-content:center;font-size:.9rem;transition:all .15s; }
.cal-nav-btn:hover { background:#3b82f6;color:#fff;border-color:#3b82f6; }
.cal-today-btn { padding:5px 14px;border-radius:8px;border:1px solid #e2e8f0;background:#fff;color:#475569;cursor:pointer;font-size:.8rem;font-weight:600;transition:all .15s; }
.cal-today-btn:hover { background:#1e293b;color:#fff;border-color:#1e293b; }

.cal-grid { display:grid;grid-template-columns:repeat(7,1fr); }
.cal-dow { text-align:center;padding:10px 4px;font-size:.72rem;font-weight:700;text-transform:uppercase;letter-spacing:.06em;color:#94a3b8;background:#f8fafc;border-bottom:1px solid #e2e8f0; }
.cal-cell { min-height:90px;padding:8px 6px 6px;border-right:1px solid #f1f5f9;border-bottom:1px solid #f1f5f9;transition:background .12s;position:relative; }
.cal-cell:nth-child(7n) { border-right:none; }
.cal-cell.clickable { cursor:pointer; }
.cal-cell.clickable:hover { background:#f0f9ff; }
.cal-cell.is-today .day-num { background:#3b82f6;color:#fff;border-radius:50%; }
.cal-cell.out-month { background:#fafbfc; }
.cal-cell.out-month .day-num { color:#cbd5e1; }
.day-num { display:inline-flex;align-items:center;justify-content:center;width:26px;height:26px;font-size:.82rem;font-weight:600;color:#475569;border-radius:50%;margin-bottom:4px; }
.day-events { display:flex;flex-wrap:wrap;gap:3px;margin-top:4px; }
.ev-chip { display:inline-flex;align-items:center;padding:2px 7px;border-radius:5px;font-size:.68rem;font-weight:700;color:#fff;line-height:1.4; }
.ev-man  { background:var(--color_man); }
.ev-mc   { background:var(--color_mc); }
.ev-mold { background:var(--color_mold); }
.ev-met  { background:var(--color_met); }
.ev-part { background:var(--color_part); }

.btn-add-cp { display:flex;align-items:center;gap:7px;padding:9px 18px;background:#3b82f6;color:#fff;border:none;border-radius:9px;font-size:.88rem;font-weight:600;cursor:pointer;transition:background .15s,transform .1s;box-shadow:0 2px 8px rgba(59,130,246,.35); }
.btn-add-cp:hover { background:#2563eb;transform:translateY(-1px); }

/* ── My CP tracking section ── */
.my-cp-section { margin-top:24px;background:#fff;border-radius:16px;box-shadow:0 2px 14px rgba(0,0,0,.07);overflow:hidden; }
.my-cp-header { display:flex;align-items:center;justify-content:space-between;padding:14px 20px;border-bottom:1px solid #e2e8f0;background:#f8fafc; }
.my-cp-header-title { font-size:.95rem;font-weight:700;color:#1e293b;display:flex;align-items:center;gap:8px; }
.my-cp-count { font-size:.78rem;background:#dbeafe;color:#1d4ed8;border-radius:20px;padding:3px 10px;font-weight:600; }
.my-cp-list { padding:12px 16px;display:flex;flex-direction:column;gap:10px;max-height:400px;overflow-y:auto; }
.my-cp-card { display:flex;align-items:center;gap:14px;padding:12px 16px;border-radius:10px;border:1px solid #e2e8f0;cursor:pointer;transition:box-shadow .15s,border-color .15s; }
.my-cp-card:hover { box-shadow:0 4px 16px rgba(0,0,0,.09);border-color:#93c5fd; }
.my-cp-type-dot { width:10px;height:10px;border-radius:50%;flex-shrink:0; }
.my-cp-info { flex:1;min-width:0; }
.my-cp-date { font-size:.75rem;color:#94a3b8;font-weight:500; }
.my-cp-title { font-size:.85rem;font-weight:600;color:#1e293b;white-space:nowrap;overflow:hidden;text-overflow:ellipsis; }
.my-cp-subtitle { font-size:.75rem;color:#64748b;margin-top:1px; }
.badge-approved { display:inline-flex;align-items:center;gap:4px;background:#dcfce7;color:#15803d;border:1px solid #bbf7d0;border-radius:20px;padding:3px 10px;font-size:.72rem;font-weight:600;white-space:nowrap; }
.badge-pending  { display:inline-flex;align-items:center;gap:4px;background:#fef9c3;color:#a16207;border:1px solid #fde047;border-radius:20px;padding:3px 10px;font-size:.72rem;font-weight:600;white-space:nowrap; }
.my-cp-empty { padding:32px;text-align:center;color:#94a3b8;font-size:.88rem; }

/* ── Modal header ── */
.modal-header-cp { padding:0;display:flex;align-items:stretch;border-bottom:1px solid #e2e8f0; }
.mhcp-color-bar { width:6px;flex-shrink:0;border-radius:0; }
.mhcp-content { flex:1;display:flex;align-items:center;gap:10px;padding:14px 18px; }
.modal-type-dot { width:12px;height:12px;border-radius:50%;flex-shrink:0; }
.form-label-cp { font-size:.8rem;font-weight:600;color:#475569;margin-bottom:4px;display:block; }
.form-label-cp .th { font-weight:400;color:#94a3b8;font-size:.74rem;margin-left:4px; }

/* ── View mode (text display) ── */
.cp-vf-grid { display:grid;grid-template-columns:1fr 1fr;gap:0;border:1px solid #e2e8f0;border-radius:10px;overflow:hidden;margin-bottom:16px; }
.cp-vf-grid .cp-vf { padding:11px 16px;border-bottom:1px solid #f1f5f9; }
.cp-vf-grid .cp-vf:nth-last-child(-n+2) { border-bottom:none; }
.cp-vf-grid .cp-vf.full { grid-column:1/-1; }
.cp-vf-label { font-size:.72rem;font-weight:600;color:#94a3b8;text-transform:uppercase;letter-spacing:.06em;margin-bottom:2px; }
.cp-vf-value { font-size:.88rem;font-weight:500;color:#1e293b; }
.cp-vf-value.empty { color:#cbd5e1;font-style:italic; }

.cp-view-files { display:flex;flex-wrap:wrap;gap:10px;margin-top:4px; }
.cp-file-thumb { text-align:center;width:80px; }
.cp-file-thumb img { width:60px;height:45px;object-fit:contain;border-radius:6px;border:1px solid #e2e8f0; }
.cp-file-thumb p { font-size:.65rem;color:#64748b;margin:3px 0 0;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;width:80px; }

img.image-upload { width:100%;height:50px;object-fit:contain; }
.upload-item { position:relative;text-align:center; }
.upload-item .removeItem { border:none;background:none;color:red;font-size:18px;position:absolute;right:0;top:0; }
.upload-boxs { margin-top:16px; }
.upload-boxs p { text-overflow:ellipsis;overflow:hidden;width:120px;height:1.2em;white-space:nowrap;font-size:.72rem; }

#imgLightbox { display:none;position:fixed;z-index:9999;top:0;left:0;width:100%;height:100%;background:rgba(0,0,0,.85);align-items:center;justify-content:center; }
#imgLightbox.open { display:flex; }
#imgLightbox img { max-width:90vw;max-height:85vh;border-radius:8px; }
#imgLightbox .lb-close { position:absolute;top:16px;right:20px;color:#fff;font-size:2rem;cursor:pointer; }

.modal-backdrop { z-index:0 !important; }
.dp__main { width:100%; }
</style>

<div id="MainApp">

    <!-- Toolbar -->
    <div class="cal-toolbar">
        <div class="group-select">
            <select class="selectpicker" data-live-search="true" id="slt_group"
                    v-model="slt_group" v-on:change="selectGroup(slt_group)"
                    data-placeholder="เลือก Group">
                <option v-for="item in groupList" :value="item.GROUP_ID">{{item.GROUP_NAME}}</option>
            </select>
        </div>
        <div style="flex:1;"></div>
        @if (ViewBag.Data.ROLE != "V" && ViewBag.Data.ROLE != "G")
        {
            <div class="btn-group" id="btn-change" style="opacity:0;transition:opacity .4s;">
                <button type="button" class="btn-add-cp dropdown-toggle" data-bs-toggle="dropdown" aria-expanded="false">
                    <i class="fas fa-plus"></i> เพิ่ม Change Point
                </button>
                <ul class="dropdown-menu">
                    <li id="menu_1"><a class="dropdown-item" href="#" onclick="return false;" v-on:click="Open_Modal('add','1','')"><span style="color:var(--color_man);">●</span> Man</a></li>
                    <li id="menu_2"><a class="dropdown-item" href="#" onclick="return false;" v-on:click="Open_Modal('add','2','')"><span style="color:var(--color_mc);">●</span> Machine</a></li>
                    <li id="menu_3"><a class="dropdown-item" href="#" onclick="return false;" v-on:click="Open_Modal('add','3','')"><span style="color:var(--color_mold);">●</span> Mold/DIE</a></li>
                    <li id="menu_4"><a class="dropdown-item" href="#" onclick="return false;" v-on:click="Open_Modal('add','4','')"><span style="color:var(--color_met);">●</span> Method</a></li>
                    <li id="menu_5"><a class="dropdown-item" href="#" onclick="return false;" v-on:click="Open_Modal('add','5','')"><span style="color:var(--color_part);">●</span> Part/Mat'l</a></li>
                </ul>
            </div>
        }
    </div>

    <!-- Stats -->
    <div class="stats-row">
        <span class="stat-chip chip-man"> <span class="sd sd-man"></span>  Man <b style="margin-left:4px;">{{monthStats.man}}</b></span>
        <span class="stat-chip chip-mc">  <span class="sd sd-mc"></span>   Machine <b style="margin-left:4px;">{{monthStats.mc}}</b></span>
        <span class="stat-chip chip-mold"><span class="sd sd-mold"></span> Mold/DIE <b style="margin-left:4px;">{{monthStats.mold}}</b></span>
        <span class="stat-chip chip-met"> <span class="sd sd-met"></span>  Method <b style="margin-left:4px;">{{monthStats.met}}</b></span>
        <span class="stat-chip chip-part"><span class="sd sd-part"></span> Part/Mat'l <b style="margin-left:4px;">{{monthStats.part}}</b></span>
    </div>

    <!-- Calendar -->
    <div class="cal-card">
        <div class="cal-head">
            <span class="cal-month-label">{{monthName}} {{currentYear}}</span>
            <div class="cal-nav-btns">
                <button class="cal-today-btn" v-on:click="goToToday">วันนี้</button>
                <button class="cal-nav-btn" v-on:click="prevMonth"><i class="fas fa-chevron-left"></i></button>
                <button class="cal-nav-btn" v-on:click="nextMonth"><i class="fas fa-chevron-right"></i></button>
            </div>
        </div>
        <div class="cal-grid">
            <div class="cal-dow">จ</div>
            <div class="cal-dow">อ</div>
            <div class="cal-dow">พ</div>
            <div class="cal-dow">พฤ</div>
            <div class="cal-dow">ศ</div>
            <div class="cal-dow" style="color:#ef4444;">ส</div>
            <div class="cal-dow" style="color:#3b82f6;">อา</div>

            <div v-for="(cell, idx) in calendarDays" :key="idx"
                 class="cal-cell"
                 :class="{ 'clickable': cell.day && cell.events.length>0, 'is-today': cell.isToday, 'out-month': !cell.day }"
                 v-on:click="cell.day && cell.events.length>0 ? navigateToDetail(cell.dateKey) : null">
                <span class="day-num" v-if="cell.day">{{cell.day}}</span>
                <div class="day-events" v-if="cell.day && cell.events.length>0">
                    <span v-for="ev in cell.events" class="ev-chip" :class="'ev-'+ev.type">{{ev.count}}</span>
                </div>
            </div>
        </div>
    </div>

    <!-- My Change Points (Member/Admin only) -->
    @if (ViewBag.Data.ROLE == "M" || ViewBag.Data.ROLE == "A")
    {
        <div class="my-cp-section">
            <div class="my-cp-header">
                <div class="my-cp-header-title">
                    <i class="fas fa-clipboard-list" style="color:#3b82f6;"></i>
                    Change Points ที่ฉันแจ้ง
                </div>
                <span class="my-cp-count">{{myList.length}} รายการ</span>
            </div>
            <div class="my-cp-list" v-if="myList.length > 0">
                <div v-for="item in myList" class="my-cp-card" v-on:click="Open_View_Modal(item)">
                    <div class="my-cp-type-dot" :style="`background:${cpTypeColor(item.STATUS_TYPE)}`"></div>
                    <div class="my-cp-info">
                        <div class="my-cp-date">{{ cpDateDisplay(item.DATE_CHANGE) }}</div>
                        <div class="my-cp-title">{{ cpTypeLabel(item.STATUS_TYPE) }} — {{ cpBrief(item) }}</div>
                        <div class="my-cp-subtitle" v-if="item.CREATE_DATE">แจ้ง {{ item.CREATE_DATE }}</div>
                    </div>
                    <div>
                        <span v-if="item.INFORMED=='Y'" class="badge-approved"><i class="fas fa-check-circle"></i> อนุมัติแล้ว</span>
                        <span v-else class="badge-pending"><i class="fas fa-clock"></i> รออนุมัติ</span>
                    </div>
                </div>
            </div>
            <div v-else class="my-cp-empty"><i class="fas fa-inbox" style="font-size:1.5rem;opacity:.4;display:block;margin-bottom:8px;"></i>ยังไม่มี Change Point ที่แจ้ง</div>
        </div>
    }

    <!-- Change Point Modal -->
    <div class="modal fade modal-lg" id="change_point_modal"
         data-bs-backdrop="static" data-bs-keyboard="false"
         tabindex="-1" aria-hidden="true">
        <div class="modal-dialog modal-dialog-scrollable">
            <div class="modal-content" style="border-radius:14px;overflow:hidden;">

                <!-- Modal Header -->
                <div class="modal-header-cp">
                    <div class="mhcp-color-bar" :style="`background:${typeColor}`"></div>
                    <div class="mhcp-content">
                        <span class="modal-type-dot" :style="`background:${typeColor}`"></span>
                        <div>
                            <div style="font-size:1rem;font-weight:700;color:#1e293b;">Change Point — {{title_modal}}</div>
                            <div v-if="viewMode" style="font-size:.75rem;color:#64748b;margin-top:2px;">{{ view_date_display }}</div>
                        </div>
                        <div style="margin-left:auto;display:flex;align-items:center;gap:10px;">
                            <div v-if="viewMode">
                                <span v-if="view_informed=='Y'" class="badge-approved"><i class="fas fa-check-circle"></i> อนุมัติแล้ว</span>
                                <span v-else class="badge-pending"><i class="fas fa-clock"></i> รออนุมัติ</span>
                            </div>
                            <div v-if="!viewMode" style="max-width:160px;">
                                @if (ViewBag.Data.ROLE != "V" && ViewBag.Data.ROLE != "G")
                                {
                                    <Datepicker v-model="date_select" :enable-time-picker="false" :clearable="false"
                                                :monthChangeOnScroll="false" :format="dateFormat" auto-apply></Datepicker>
                                }
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Modal Body: VIEW mode (text display) -->
                <div v-if="viewMode" class="modal-body" style="padding:0;">

                    <div style="padding:16px 20px;border-bottom:1px solid #e2e8f0;display:flex;flex-wrap:wrap;gap:12px;align-items:center;">
                        <div>
                            <div style="font-size:.72rem;font-weight:600;color:#94a3b8;text-transform:uppercase;letter-spacing:.06em;margin-bottom:2px;">ผู้แจ้ง</div>
                            <div style="font-size:.88rem;font-weight:500;color:#1e293b;">{{ view_creator }}</div>
                        </div>
                    </div>

                    <div style="padding:16px 20px;">

                        <div class="cp-vf-grid">
                            <div id="vb_from" class="cp-vf">
                                <div class="cp-vf-label">คนประจำจุด</div>
                                <div class="cp-vf-value" :class="!view_spot_name?'empty':''">{{ view_spot_name || '—' }}</div>
                            </div>
                            <div id="vb_to" class="cp-vf">
                                <div class="cp-vf-label">คนแทนจุด</div>
                                <div class="cp-vf-value" :class="!view_instead_name?'empty':''">{{ view_instead_name || '—' }}</div>
                            </div>
                            <div id="vb_mc" class="cp-vf">
                                <div class="cp-vf-label">M/C NO.</div>
                                <div class="cp-vf-value" :class="!slt_mc_no?'empty':''">{{ slt_mc_no || '—' }}</div>
                            </div>
                            <div id="vb_edit" class="cp-vf">
                                <div class="cp-vf-label">จุดที่แก้ไข</div>
                                <div class="cp-vf-value" :class="!slt_edit?'empty':''">{{ slt_edit || '—' }}</div>
                            </div>
                            <div id="vb_part" class="cp-vf">
                                <div class="cp-vf-label">Part NO.</div>
                                <div class="cp-vf-value" :class="!slt_part_no?'empty':''">{{ slt_part_no || '—' }}</div>
                            </div>
                            <div id="vb_mold" class="cp-vf">
                                <div class="cp-vf-label">Mold NO.</div>
                                <div class="cp-vf-value" :class="!slt_mold_no?'empty':''">{{ slt_mold_no || '—' }}</div>
                            </div>
                            <div id="vb_change" class="cp-vf">
                                <div class="cp-vf-label">หัวข้อการเปลี่ยนแปลง</div>
                                <div class="cp-vf-value" :class="!slt_change?'empty':''">{{ slt_change || '—' }}</div>
                            </div>
                            <div id="vb_process" class="cp-vf">
                                <div class="cp-vf-label">Process</div>
                                <div class="cp-vf-value" :class="!slt_process?'empty':''">{{ slt_process || '—' }}</div>
                            </div>
                        </div>

                        <div v-if="slt_detail" style="margin-bottom:16px;">
                            <div style="font-size:.75rem;font-weight:700;color:#475569;text-transform:uppercase;letter-spacing:.05em;margin-bottom:6px;">รายละเอียด</div>
                            <div style="background:#f8fafc;border:1px solid #e2e8f0;border-radius:8px;padding:10px 14px;font-size:.85rem;color:#1e293b;white-space:pre-wrap;">{{ slt_detail }}</div>
                        </div>

                        <div v-if="slt_warning" style="margin-bottom:16px;">
                            <div style="font-size:.75rem;font-weight:700;color:#dc2626;text-transform:uppercase;letter-spacing:.05em;margin-bottom:6px;">ข้อควรระวัง</div>
                            <div style="background:#fff5f5;border:1px solid #fecaca;border-radius:8px;padding:10px 14px;font-size:.85rem;color:#dc2626;white-space:pre-wrap;">{{ slt_warning }}</div>
                        </div>

                        <div v-if="fileList.length > 0" style="margin-bottom:16px;">
                            <div style="font-size:.75rem;font-weight:700;color:#475569;text-transform:uppercase;letter-spacing:.05em;margin-bottom:8px;">ไฟล์ / รูป</div>
                            <div class="cp-view-files">
                                <a v-for="f in fileList" :href="'/src/upload/'+f.name" target="_blank"
                                   class="cp-file-thumb" :download="f.file_type!='image'">
                                    <img v-if="f.file_type=='image'" :src="'/src/upload/'+f.name" :title="f.name" onclick="openLightbox(this);event.preventDefault();" style="cursor:zoom-in;" />
                                    <img v-else :src="'/src/icons/'+(f.file_type=='pdf'?'pdf':f.file_type=='excel'?'xls':f.file_type=='powerpoint'?'ppt':f.file_type=='word'?'word':'text')+'.png'" />
                                    <p :title="f.name">{{f.name}}</p>
                                </a>
                            </div>
                        </div>

                    </div>
                </div>

                <!-- Modal Body: EDIT/ADD mode (form inputs) -->
                @if (ViewBag.Data.ROLE != "V" && ViewBag.Data.ROLE != "G")
                {
                    <div v-if="!viewMode" class="modal-body" style="padding:20px;">
                        <div class="row g-3">

                            <div id="b_from" class="col-md-6">
                                <label id="lb_from" class="form-label-cp">Employee on leave <span class="th">คนประจำจุด</span></label>
                                <select class="selectpicker" data-live-search="true" id="slt_spot" v-model="slt_spot" data-placeholder="Select"><optgroup v-for="items in userList" :label="items.wc_code+':'+items.wc_name"><option v-for="item in items.list" :value="item.itemId">{{item.itemId}} : {{item.gname_tha}} {{item.fname_tha}}</option></optgroup></select>
                            </div>

                            <div id="b_to" class="col-md-6">
                                <label id="lb_to" class="form-label-cp">Replacement employee <span class="th">คนแทนจุด</span></label>
                                <select class="selectpicker" data-live-search="true" id="slt_instead" v-model="slt_instead" data-placeholder="Select"><optgroup v-for="items in userList" :label="items.wc_code+':'+items.wc_name"><option v-for="item in items.list" :value="item.itemId">{{item.itemId}} : {{item.gname_tha}} {{item.fname_tha}}</option></optgroup></select>
                            </div>

                            <div id="b_mc" class="col-md-6">
                                <label id="lb_mc" class="form-label-cp">M/C NO. <span class="th">เครื่องจักร</span></label>
                                <select class="selectpicker" data-live-search="true" id="slt_mc_no" v-model="slt_mc_no" data-placeholder="Select"><optgroup v-for="items in mcsList" :label="items.sizeTon"><option v-for="item in items.list">{{item}}</option></optgroup></select>
                            </div>

                            <div id="b_eidt" class="col-md-6">
                                <label id="lb_eidt" class="form-label-cp">Edit point <span class="th">จุดที่แก้ไข</span></label>
                                <select class="selectpicker" data-live-search="true" id="slt_edit" v-model="slt_edit" data-placeholder="Select"><option v-for="item in editList" :value="item.ITEM_NAME">{{item.ITEM_NAME}}</option></select>
                            </div>

                            <div id="b_part" class="col-md-6">
                                <label id="lb_part" class="form-label-cp">Part NO.</label>
                                <select class="selectpicker" data-live-search="true" id="slt_part_no" v-model="slt_part_no" data-placeholder="Select"><option v-for="item in partsList">{{item.ITEM_ID}}</option></select>
                            </div>

                            <div id="b_mold" class="col-md-6">
                                <label id="lb_mold" class="form-label-cp">Mold NO.</label>
                                <select class="selectpicker" data-live-search="true" id="slt_mold_no" v-model="slt_mold_no" data-placeholder="Select"><option v-for="item in moldNOList" :value="item.ITEM_NAME">{{item.ITEM_NAME}}</option></select>
                            </div>

                            <div id="b_change" class="col-md-6">
                                <label id="lb_change" class="form-label-cp">Change topic <span class="th">หัวข้อการเปลี่ยนแปลง</span></label>
                                <select class="selectpicker" data-live-search="true" id="slt_change" v-model="slt_change" data-placeholder="Select"><option v-for="item in changeList" :value="item.ITEM_NAME">{{item.ITEM_NAME}}</option></select>
                            </div>

                            <div id="b_process" class="col-md-6">
                                <label id="lb_process" class="form-label-cp">Process</label>
                                <select class="selectpicker" data-live-search="true" id="slt_process" v-model="slt_process" data-placeholder="Select"><option v-for="item in processList" :value="item.ITEM_NAME">{{item.ITEM_NAME}}</option></select>
                            </div>

                            <div class="col-12">
                                <label class="form-label-cp">Detail <span class="th">รายละเอียด</span></label>
                                <textarea class="form-control" rows="3" id="slt_detail_input" v-model="slt_detail" placeholder="รายละเอียด..."></textarea>
                            </div>

                            <div class="col-12">
                                <label class="form-label-cp">Warning <span class="th">ข้อควรระวัง</span></label>
                                <textarea class="form-control" rows="3" id="slt_warning_input" v-model="slt_warning" placeholder="ข้อควรระวัง..."></textarea>
                            </div>

                            <div id="b_file" class="col-12">
                                <label id="lb_file" class="form-label-cp">รูป / เอกสาร (ถ้ามี)</label>
                                <input class="form-control form-control-sm" type="file" id="formFileMultiple" v-on:change="onFileChange" accept="image/*,.pdf,.xlsx,.docx,.pptx,.txt" multiple />
                                <div v-if="fileList.length>0" class="row mt-2">
                                    <div v-for="(f,fi) in fileList" class="col-4 upload-boxs">
                                        <div class="upload-item">
                                            <img v-if="f.file_type=='image'" class="image-upload" :src="'/src/upload/'+f.name" :title="f.name" onclick="openLightbox(this)" style="cursor:pointer;" />
                                            <a v-else :href="'/src/upload/'+f.name" target="_blank" download>
                                                <img class="image-upload" style="cursor:pointer;" :src="'/src/icons/'+(f.file_type=='pdf'?'pdf':f.file_type=='excel'?'xls':f.file_type=='powerpoint'?'ppt':f.file_type=='word'?'word':'text')+'.png'" />
                                            </a>
                                            <p :title="f.name">{{f.name}}</p>
                                            <button class="removeItem" onclick="return false;" v-on:click="removeImage(fi)"><i class="fas fa-times-circle"></i></button>
                                        </div>
                                    </div>
                                </div>
                            </div>

                        </div>
                    </div>
                }

                <!-- Modal Footer -->
                <div class="modal-footer" style="border-top:1px solid #e2e8f0;padding:12px 20px;gap:8px;">
                    @if (ViewBag.Data.ROLE != "V" && ViewBag.Data.ROLE != "G")
                    {
                        <template v-if="!viewMode">
                            <button type="button" class="btn btn-outline-secondary btn-sm" id="btn-cn" v-on:click="cancelAdd">
                                <i class="fas fa-times"></i> Cancel
                            </button>
                            <button type="button" class="btn btn-outline-danger btn-sm" v-if="!IsAdd" id="btn-d" v-on:click="deleteItem">
                                <i class="fas fa-trash"></i> ลบ
                            </button>
                            <button type="button" class="btn btn-primary btn-sm" id="btn-s" v-on:click="Save_Data()">
                                <i class="fas fa-save"></i> บันทึก
                            </button>
                        </template>
                        <template v-else>
                            <button type="button" class="btn btn-outline-secondary btn-sm" data-bs-dismiss="modal"><i class="fas fa-times"></i> ปิด</button>
                        </template>
                    }
                    else
                    {<button type="button" class="btn btn-outline-secondary btn-sm" data-bs-dismiss="modal"><i class="fas fa-times"></i> ปิด</button>}
                </div>

            </div>
        </div>
    </div>

</div>

<div id="imgLightbox">
    <span class="lb-close" onclick="closeLightbox()">&times;</span>
    <img id="lbImg" src="" alt="" />
</div>

@Scripts.Render("~/Scripts/bootstrap-select.min.js")

<script>
    $("#MainApp").delay(300).fadeIn(400);
    function openLightbox(img){ document.getElementById('lbImg').src=img.src; document.getElementById('imgLightbox').classList.add('open'); }
    function closeLightbox(){ document.getElementById('imgLightbox').classList.remove('open'); }

    const IS_VIEWER = '@(ViewBag.Data.ROLE == "V" || ViewBag.Data.ROLE == "G" ? "true" : "false")' === 'true';

    const { createApp } = Vue;
    createApp({
        data() {
            return {
                currentYear:  new Date().getFullYear(),
                currentMonth: new Date().getMonth(),
                eventMap: {},
                myList: [],
                date_select: new Date(),
                dateFormat: (d) => `${d.getDate()}/${d.getMonth()+1}/${d.getFullYear()}`,
                changeType:'', fileList:[], images:[], tempID:[], fileSize:0,
                userList:[], mcsList:[], partsList:[], moldNOList:[], editList:[], changeList:[], processList:[],
                dataList:[], dataNameList:[],
                slt_id:'', slt_spot:'', slt_instead:'',
                slt_mc_no:'', slt_edit:'', slt_part_no:'', slt_mold_no:'', slt_change:'',
                slt_process:'', slt_detail:'', slt_warning:'', slt_group:'',
                modal_type:'', title_modal:'',
                groupList:[], IsAdd:false, color_list:[], root:null,
                viewMode: IS_VIEWER,
                view_informed: '',
                view_date_display: '',
                view_creator: '',
                view_spot_name: '',
                view_instead_name: '',
            };
        },
        components: { Datepicker: VueDatePicker },
        computed: {
            monthName() {
                return ['มกราคม','กุมภาพันธ์','มีนาคม','เมษายน','พฤษภาคม','มิถุนายน',
                        'กรกฎาคม','สิงหาคม','กันยายน','ตุลาคม','พฤศจิกายน','ธันวาคม'][this.currentMonth];
            },
            calendarDays() {
                const y=this.currentYear, m=this.currentMonth;
                let first = new Date(y,m,1).getDay();
                first = (first+6)%7;
                const dim = new Date(y,m+1,0).getDate();
                const today = new Date();
                const cells = [];
                for(let i=0;i<first;i++) cells.push({day:null,dateKey:null,events:[],isToday:false});
                for(let d=1;d<=dim;d++){
                    const mm=String(m+1).padStart(2,'0'), dd=String(d).padStart(2,'0');
                    const dateKey=`${mm}/${dd}/${y}`;
                    cells.push({ day:d, dateKey, events:this.eventMap[dateKey]||[],
                        isToday:(y===today.getFullYear()&&m===today.getMonth()&&d===today.getDate()) });
                }
                return cells;
            },
            monthStats() {
                const s={man:0,mc:0,mold:0,met:0,part:0};
                const pre=`${String(this.currentMonth+1).padStart(2,'0')}/`, suf=`/${this.currentYear}`;
                for(const [k,evs] of Object.entries(this.eventMap)){
                    if(!k.startsWith(pre)||!k.endsWith(suf)) continue;
                    evs.forEach(e=>{ if(s[e.type]!==undefined) s[e.type]+=e.count; });
                }
                return s;
            },
            typeColor() {
                return {'1':'var(--color_man)','2':'var(--color_mc)','3':'var(--color_mold)','4':'var(--color_met)','5':'var(--color_part)'}[this.modal_type]||'#94a3b8';
            },
        },
        async created() {
            const self=this;
            await self.getGroup();
            await self.getList();
            await self.getMoldNO(); await self.getProcess(); await self.getEdit();
            await self.getChange(); await self.getPart(); await self.getMC(); await self.getUser();
            await self.deleteChangePointOver();
            await self.getMyList();
            await $('#slt_spot,#slt_instead,#slt_mc_no,#slt_edit,#slt_part_no,#slt_mold_no,#slt_change,#slt_process').selectpicker('destroy');
            await $('select').selectpicker('render');
            await $("#btn-change").css('opacity','1');
            await self.get_colors();
        },
        async mounted() { this.root=document.documentElement; },
        methods: {
            prevMonth(){ if(this.currentMonth===0){this.currentMonth=11;this.currentYear--;}else{this.currentMonth--;} },
            nextMonth(){ if(this.currentMonth===11){this.currentMonth=0;this.currentYear++;}else{this.currentMonth++;} },
            goToToday(){ const t=new Date(); this.currentYear=t.getFullYear(); this.currentMonth=t.getMonth(); },
            navigateToDetail(dateKey){ if(!dateKey) return; window.open('@Url.Action("detail","home_ver1",new{id="id_date"})'.replace("id_date",dateKey.replaceAll("/","")),'_self'); },

            cpTypeColor(t){ return {'1':'var(--color_man)','2':'var(--color_mc)','3':'var(--color_mold)','4':'var(--color_met)','5':'var(--color_part)'}[t]||'#94a3b8'; },
            cpTypeLabel(t){ return {'1':'Man','2':'Machine','3':'Mold/DIE','4':'Method','5':"Part/Mat'l"}[t]||''; },
            cpBrief(item){
                if(item.STATUS_TYPE==='1') return item.MAN_SPOT_NAME_THA||item.MAN_SPOT||'—';
                if(item.STATUS_TYPE==='2') return item.MC_NO||'—';
                if(item.STATUS_TYPE==='3') return item.MOLD_NO||item.PART_NO||'—';
                if(item.STATUS_TYPE==='4') return item.MC_NO||item.PART_NO||'—';
                if(item.STATUS_TYPE==='5') return item.PART_NO||item.MC_NO||'—';
                return '—';
            },
            cpDateDisplay(dateStr){
                if(!dateStr) return '';
                try { const d=new Date(dateStr); return `${d.getDate()}/${d.getMonth()+1}/${d.getFullYear()}`; } catch(e){ return dateStr; }
            },

            async getList() {
                const self=this;
                await $.ajax({ url:"@Url.Action("ListItem_ChangePoint_All","lookup_ver1")", type:"POST", data:{},
                    success(r){
                        if(!r.success) return;
                        const map={};
                        r.data.forEach(item=>{
                            const dates=new Date(item.DATE_CHANGE);
                            const mm=String(dates.getMonth()+1).padStart(2,'0'), dd=String(dates.getDate()).padStart(2,'0');
                            const dk=`${mm}/${dd}/${dates.getFullYear()}`;
                            const type={'1':'man','2':'mc','3':'mold','4':'met','5':'part'}[item.STATUS_TYPE]||'unknown';
                            if(!map[dk]) map[dk]=[];
                            const ex=map[dk].find(e=>e.type===type);
                            if(ex){ex.count++;}else{map[dk].push({type,count:1});}
                        });
                        self.eventMap=map;
                    }
                });
            },
            async getMyList(){
                const self=this;
                await $.ajax({ url:"@Url.Action("ListItem_ChangePoint_My","lookup_ver1")", type:"POST", data:{},
                    success(r){ if(r.success) self.myList=r.data||[]; }
                });
            },
            async getProcess(){ const self=this; await $.ajax({ url:"@Url.Action("Option_Process","lookup")", type:"POST", data:{}, success(r){ if(r.success) self.processList=r.data; } }); },
            async getMoldNO(){ const self=this; await $.ajax({ url:"@Url.Action("Option_Mold_NO","lookup")", type:"POST", data:{}, success(r){ if(r.success) self.moldNOList=r.data; } }); },
            async getEdit(){ const self=this; await $.ajax({ url:"@Url.Action("Option_Edit","lookup")", type:"POST", data:{}, success(r){ if(r.success) self.editList=r.data; } }); },
            async getChange(){ const self=this; await $.ajax({ url:"@Url.Action("Option_Change","lookup")", type:"POST", data:{}, success(r){ if(r.success) self.changeList=r.data; } }); },
            async getPart(){ const self=this; await $.ajax({ url:"@Url.Action("ListItem_Part","lookup")", type:"POST", data:{}, success(r){ if(r.success) self.partsList=r.data; } }); },
            async getMC(){
                const self=this;
                await $.ajax({ url:"@Url.Action("ListItem_MC","lookup")", type:"POST", data:{},
                    success(r){ if(!r.success) return; const t={}; r.data.forEach(i=>{ if(t[i.ITEM_SIZETON]) t[i.ITEM_SIZETON].list.push(i.ITEM_NAME); else t[i.ITEM_SIZETON]={sizeTon:i.ITEM_SIZETON,list:[i.ITEM_NAME]}; }); self.mcsList=Object.values(t); }
                });
            },
            async getUser(){
                const self=this;
                await $.ajax({ url:"@Url.Action("Option_EMP","lookup")", type:"POST", data:{},
                    success(r){ if(!r.success) return; self.dataNameList=r.data; const t={}; r.data.forEach(i=>{ if(t[i.WC_CODE]) t[i.WC_CODE].list.push({itemId:i.EMP_NO,gname_tha:i.GNAME_TH,fname_tha:i.FNAME_TH,gname_eng:i.GNAME_ENG,fname_eng:i.FNAME_ENG}); else t[i.WC_CODE]={wc_code:i.WC_CODE,wc_name:i.WC_NAME,list:[{itemId:i.EMP_NO,gname_tha:i.GNAME_TH,fname_tha:i.FNAME_TH,gname_eng:i.GNAME_ENG,fname_eng:i.FNAME_ENG}]}; }); self.userList=Object.values(t); }
                });
            },
            async getGroup(){
                const self=this;
                await $.ajax({ url:"@Url.Action("SelectItem_GROUP_WC_ByWC","lookup_ver1")", type:"POST", data:{},
                    success(r){ if(!r.success) return; self.groupList=r.data; self.slt_group='@Session["GROUP_ID"].ToString()'; if(self.slt_group==='') self.slt_group=r.data[0].GROUP_ID; const idx=r.data.findIndex(o=>o.GROUP_ID===self.slt_group); if(idx<0) return; const s=r.data[idx]; if(s.MENU_1==='N') $('#menu_1').hide(); if(s.MENU_2==='N') $('#menu_2').hide(); if(s.MENU_3==='N') $('#menu_3').hide(); if(s.MENU_4==='N') $('#menu_4').hide(); if(s.MENU_5==='N') $('#menu_5').hide(); }
                });
                await $('#slt_group').selectpicker('destroy'); await $('#slt_group').selectpicker('render'); await $("#slt_group").selectpicker("val",this.slt_group);
            },
            async selectGroup(gID){ await $.ajax({ url:"@Url.Action("Select_GROUP","lookup_ver1")", type:"POST", data:{ item_group:gID }, success(r){ if(r.success) window.open("@Url.Action("index","home_ver1")","_self"); } }); },
            async get_colors(){
                const self=this;
                await $.ajax({ url:"@Url.Action("SelectItem_Colors","lookup")", type:"POST", data:{}, success(r){ if(r.success&&r.data.length>0){ const c=r.data[0]; self.root.style.setProperty("--color_man",c.ITEM_COLORS_1); self.root.style.setProperty("--color_mc",c.ITEM_COLORS_2); self.root.style.setProperty("--color_mold",c.ITEM_COLORS_3); self.root.style.setProperty("--color_met",c.ITEM_COLORS_4); self.root.style.setProperty("--color_part",c.ITEM_COLORS_5); } } });
            },

            _setViewFields(info){
                const self=this;
                self.modal_type=info.STATUS_TYPE;
                self.title_modal=self.cpTypeLabel(info.STATUS_TYPE);
                self.view_informed=info.INFORMED;
                self.view_date_display=self.cpDateDisplay(info.DATE_CHANGE);
                self.view_creator=`${info.GNAME_ENG_CREATE||''} ${info.FNAME_ENG_CREATE||''}`.trim()||info.CREATE_BY||'—';
                self.view_spot_name=info.MAN_SPOT_NAME_THA||info.MAN_SPOT||'';
                self.view_instead_name=info.MAN_INSTEAD_NAME_THA||info.MAN_INSTEAD||'';
                self.slt_id=info.ID;
                self.slt_spot=info.MAN_SPOT; self.slt_instead=info.MAN_INSTEAD;
                self.slt_mc_no=info.MC_NO; self.slt_edit=info.EDIT_POINT;
                self.slt_part_no=info.PART_NO; self.slt_mold_no=info.MOLD_NO;
                self.slt_change=info.CHANGE; self.slt_process=info.PROCESS_POINT;
                self.slt_detail=info.DETAILS||'';
                self.slt_warning=info.WARNINGS||'';
            },

            async Open_View_Modal(item){
                const self=this;
                self.viewMode=true;
                self._setViewFields(item);
                self.fileList=[];
                await self.getFileList(item.ID);
                const modal=bootstrap.Modal.getOrCreateInstance(document.querySelector('#change_point_modal'));
                modal.show();
            },

            async Open_Modal(status,type,id){
                const self=this;
                self.viewMode=IS_VIEWER;
                const modal=bootstrap.Modal.getOrCreateInstance(document.querySelector('#change_point_modal'));
                self.changeType=type; self.modal_type=type;

                if(IS_VIEWER){
                    modal.show(); return;
                }

                $('[id^="lb_"],[id^="b_"]').hide();
                switch(type){
                    case '1': $('#lb_from,#lb_to,#lb_mc,#lb_process,#b_from,#b_to,#b_mc,#b_process').show(); self.title_modal='Man'; break;
                    case '2': $('#lb_eidt,#lb_mc,#lb_file,#b_eidt,#b_mc,#b_file').show(); self.title_modal='M/C'; break;
                    case '3': $('#lb_mold,#lb_part,#lb_file,#b_mold,#b_part,#b_file').show(); self.title_modal='Mold/DIE'; break;
                    case '4': $('#lb_mc,#lb_part,#lb_file,#b_mc,#b_part,#b_file').show(); self.title_modal='Method'; break;
                    case '5': $('#lb_mc,#lb_part,#lb_change,#lb_file,#b_mc,#b_part,#b_change,#b_file').show(); self.title_modal="Part/Mat'l"; break;
                }
                if(status==='add'){
                    self.IsAdd=true;
                    $('#slt_spot,#slt_instead,#slt_mc_no,#slt_edit,#slt_part_no,#slt_mold_no,#slt_change,#slt_process').selectpicker('val','');
                    Object.assign(self,{slt_id:'',slt_spot:'',slt_instead:'',slt_mc_no:'',slt_edit:'',slt_mold_no:'',slt_part_no:'',slt_process:'',slt_change:'',slt_detail:'',slt_warning:'',fileList:[],images:[],tempID:[]});
                    $("#formFileMultiple").val(null);
                } else {
                    self.IsAdd=false;
                    const info=self.dataList.find(i=>i.ID===id); if(!info) return;
                    self._setViewFields(info);
                    $("#formFileMultiple").val(null);
                    await self.getFileList(self.slt_id);
                    await $("#slt_mold_no").selectpicker("val",self.slt_mold_no); await $("#slt_part_no").selectpicker("val",self.slt_part_no);
                    await $("#slt_edit").selectpicker("val",self.slt_edit); await $("#slt_process").selectpicker("val",self.slt_process);
                    await $("#slt_spot").selectpicker("val",self.slt_spot); await $("#slt_instead").selectpicker("val",self.slt_instead);
                    await $("#slt_mc_no").selectpicker("val",self.slt_mc_no); await $("#slt_change").selectpicker("val",self.slt_change);
                }
                modal.show();
            },
            async cancelAdd(){
                const self=this; const modal=bootstrap.Modal.getOrCreateInstance(document.querySelector('#change_point_modal'));
                if(self.IsAdd){ for(let i=0;i<self.fileList.length;i++){ const fd=new FormData(); fd.append('item_id',self.fileList[i].id); fd.append('item_name',self.fileList[i].name); await $.ajax({url:'@Url.Action("deleteFile","lookup_ver1")',type:'POST',data:fd,dataType:'json',contentType:false,processData:false,success(){}}); } }
                await modal.hide();
            },
            onFileChange(e){ const files=e.target.files||e.dataTransfer.files; if(!files.length) return; this.createImage(files); },
            async createImage(files){
                const self=this;
                $('#btn-cn,#btn-s').prop('disabled',true).html('<i class="fas fa-sync fa-spin"></i>');
                for(let i=0;i<files.length;i++){
                    self.fileSize+=files[i].size/(1024*1024);
                    if(self.fileSize<3){
                        const ft=files[i].type; if(ft.startsWith('image/')) files[i].file_type='image'; else if(ft.includes('pdf')) files[i].file_type='pdf'; else if(ft.includes('spreadsheet')) files[i].file_type='excel'; else if(ft.includes('presentationml')) files[i].file_type='powerpoint'; else if(ft.includes('wordprocessingml')) files[i].file_type='word'; else files[i].file_type='text';
                        self.fileList.push(files[i]);
                        const fd=new FormData(); fd.append('file',$('#formFileMultiple')[0].files[i]); fd.append('type',files[i].file_type); fd.append('size',(files[i].size/1024/1024).toFixed(4)); fd.append('id',self.slt_id);
                        await $.ajax({url:'@Url.Action("UploadFile","lookup_ver1")',type:'POST',data:fd,dataType:'json',contentType:false,processData:false, success: async function(res){ await self.tempID.push(res.data[0]); await self.getFileList(res.data[0]); }});
                    } else { self.fileSize-=files[i].size/(1024*1024); alertBoxTime('Alert','ขนาดไฟล์รวมเกิน 3 MB','warning',2000,'',''); }
                }
                $('#btn-cn').prop('disabled',false).html('<i class="fas fa-times"></i> Cancel'); $('#btn-s').prop('disabled',false).html('<i class="fas fa-save"></i> บันทึก'); $("#formFileMultiple").val(null);
            },
            removeImage(idx){ const self=this; const fd=new FormData(); if(self.IsAdd){fd.append('item_id',self.tempID[idx].ITEM_ID);fd.append('item_name',self.tempID[idx].ITEM_NAME);}else{fd.append('item_id',self.fileList[idx].id);fd.append('item_name',self.fileList[idx].name);} $.ajax({url:'@Url.Action("deleteFile","lookup_ver1")',type:'POST',data:fd,dataType:'json',contentType:false,processData:false,success(){}}); self.images.splice(idx,1);self.fileList.splice(idx,1);self.tempID.splice(idx,1); },
            async getFileList(id){
                const self=this;
                await $.ajax({url:"@Url.Action("SelectItem_Files","lookup_ver1")",type:"POST",data:{item_id:id},success(r){if(r.success){self.fileList=[];r.data.forEach(d=>self.fileList.push({id:d.ITEM_ID,name:d.ITEM_NAME,file_type:d.ITEM_FILE_TYPE,size:d.ITEM_FILE_SIZE}));}}});
            },
            async Save_Data(){
                const self=this;
                let ok=(self.slt_spot!==''||self.slt_instead!==''||self.slt_mc_no!==''||self.slt_mold_no!==''||self.slt_part_no!=='');
                if(!ok){ alertBoxTime('Alert','กรุณากรอกข้อมูลให้ครบถ้วน','warning',1500,'',''); return; }
                let se='',st='',ie='',it='';
                if(self.slt_spot!==''){ const s=self.dataNameList.find(i=>i.EMP_NO===self.slt_spot); if(s){se=s.GNAME_ENG+' '+s.FNAME_ENG;st=s.GNAME_TH+' '+s.FNAME_TH;} }
                if(self.slt_instead!==''){ const s=self.dataNameList.find(i=>i.EMP_NO===self.slt_instead); if(s){ie=s.GNAME_ENG+' '+s.FNAME_ENG;it=s.GNAME_TH+' '+s.FNAME_TH;} }
                $('#btn-cn,#btn-s').prop('disabled',true).html('<i class="fas fa-sync fa-spin"></i>');
                const p={dates:self.date_select,spot:self.slt_spot,instead:self.slt_instead,mc_no:self.slt_mc_no,edit:self.slt_edit,part_no:self.slt_part_no,mold_no:self.slt_mold_no,change:self.slt_change,process:self.slt_process,detail:self.slt_detail,warning:self.slt_warning,type:self.changeType,spot_eng:se,spot_tha:st,instead_eng:ie,instead_tha:it};
                if(!self.IsAdd) p.id=self.slt_id;
                const url=self.IsAdd?"@Url.Action("AddItem_ChangePoint","lookup_ver1")":"@Url.Action("editItem_ChangePoint","lookup_ver1")";
                $.ajax({url,type:"POST",data:p, success(r2){ swal({title:'Alert',text:r2.Message,type:r2.success?'success':'warning',timer:1200,showCancelButton:false,showConfirmButton:false}); if(r2.success) setTimeout(async()=>{ await self.getList(); await self.getMyList(); bootstrap.Modal.getOrCreateInstance(document.querySelector('#change_point_modal')).hide(); },1100); }});
                $('#btn-cn').prop('disabled',false).html('<i class="fas fa-times"></i> Cancel'); $('#btn-s').prop('disabled',false).html('<i class="fas fa-save"></i> บันทึก');
            },
            deleteItem(){
                const self=this;
                alertBoxConfirm("Alert","ต้องการลบรายการนี้ใช่ไหม?","",function(ok){ if(!ok) return; $.ajax({url:"@Url.Action("DeleteItem_ChangePoint","lookup_ver1")",type:"POST",data:{item_id:self.slt_id},success(r){swal({title:'Alert',text:r.Message,type:r.success?'success':'warning',timer:1100,showCancelButton:false,showConfirmButton:false});if(r.success) setTimeout(async()=>{ await self.getList(); await self.getMyList(); bootstrap.Modal.getOrCreateInstance(document.querySelector('#change_point_modal')).hide(); },1000);}}); });
            },
            async deleteChangePointOver(){ await $.ajax({url:"@Url.Action("ListItem_ChangePoint_Over","lookup_ver1")",type:"POST",data:{},success(r){if(r.success&&r.data.length>0) r.data.forEach(item=>{const fd=new FormData();fd.append('item_id',item.ID);$.ajax({url:'@Url.Action("DeleteItem_ChangePoint","lookup_ver1")',type:'POST',data:fd,dataType:'json',contentType:false,processData:false,success(){}});});}}); },
        }
    }).mount('#MainApp');
</script>
