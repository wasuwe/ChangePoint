@{
    ViewBag.Title = "Group";
}

@*@Styles.Render("~/Content/bootstrap-select.min.css")*@

@Styles.Render("~/Content/bootstrap-select.min.css")

<style>

    :root {
        --font_size_section_titel: 1.2rem;
        --font_size_sectionl: 1.2rem;
        --font_size_head_table: 0.8rem;
        --font_size_body_table: 0.8rem;
        --font_size_icon: 1.5rem;
        --font_size_item_title: 1rem;
        --font_size_icon_item_detail: 1rem;
    }

    html {
        min-height: 100%;
    }



    body::-webkit-scrollbar-track {
        border: 1px solid black;
        background-color: #F5F5F5;
    }

    body::-webkit-scrollbar {
        width: 10px;
        background-color: #F5F5F5;
    }

    body::-webkit-scrollbar-thumb {
        background-color: #000000;
    }


    .backTotop {
        position: fixed;
        bottom: -50px;
        right: 15px;
        font-size: 40px;
        color: #fff;
        box-shadow: rgb(0 0 0 / 35%) 0px 5px 15px;
        border-radius: 100%;
        cursor: pointer;
        transition: all 0.5s;
        background: #000000;
    }

        .backTotop.active {
            bottom: 20px;
            transition: all 0.5s;
        }

    .section-tatble {
        background: #fff;
        border-radius: 8px;
        box-shadow: rgb(0 0 0 / 35%) 0px 5px 15px;
        padding: 10px;
        margin-top: 20px;
    }


    .alertTable.alert_over {
        font-weight: bold;
        background: #ff6060;
    }

    .alertTable.alert_lower {
        font-weight: bold;
        background: #fff949;
    }


    .modal {
        display: none;
        position: fixed;
        z-index: 999;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        background-color: rgba(0, 0, 0, 0.8);
    }

    .modal-content {
        max-width: 90%;
        max-height: 90%;
        display: block;
        margin: 0 auto;
        margin-top: 30px;
    }

    .close {
        color: #fff;
        font-size: 40px;
        position: absolute;
        top: 10px;
        right: 20px;
        cursor: pointer;
    }

    .modal-backdrop {
        z-index: 0 !important;
    }

    .dp__main {
        width: 100%;
    }

    .dropdown.bootstrap-select {
        width: 100% !important;
        border: var(--bs-border-width) solid var(--bs-border-color);
        border-radius: 7px;
    }

    button.btn.dropdown-toggle.btn-light {
        background-color: var(--bs-body-bg);
        background-clip: padding-box;
    }


    .modal-header {
        color: #ffffff;
        background-color: #216583;
    }

    th.btn-updown > i {
        cursor: pointer;
    }

        th.btn-updown > i:first-child {
            /*margin-right: 5px;*/
            color: #5679ff;
        }

        th.btn-updown > i:nth-child(2) {
            color: #ff8a22;
        }

    .add-row {
        text-align: center;
        font-size: 20px;
        padding: 5px 0;
        border: 1px solid #a3a3a3;
        border-radius: 8px;
        cursor: pointer;
    }

    th.btn-remove {
        vertical-align: middle;
    }

        th.btn-remove > i {
            cursor: pointer;
            color: #ed0000;
        }

    .head-table {
        display: flex;
        flex-direction: row;
        justify-content: space-between;
        font-size: 25px;
        font-weight: bold;
        border-top: 2px solid;
        border-bottom: 2px solid;
        padding: 0 10px;
    }

    .head-btn > i {
        cursor: pointer;
        color: #005ae7;
    }

    .css-box {
        box-shadow: rgb(0 0 0 / 35%) 0px 5px 15px;
        border-radius: 8px;
        overflow: hidden;
        padding: 15px;
        margin-bottom: 40px;
    }
</style>

<div id="MainApp">

    <div class="tables-page-head">

        <div class="head-box">
            <div class="haed-title">Dashboard Setting</div>
            <div class="select-group">
                <select class="selectpicker" data-placeholder="Select Group" data-live-search="true" id="slt_group" name="slt_group" v-model="slt_group" v-on:change="selectGroup(slt_group)">
                    <option v-for="(item,index) in groupList" :value="item.GROUP_ID">{{item.GROUP_NAME}}</option>
                </select>
            </div>
        </div>

    </div>

    <div class="section-table">
        <div class="row">
            <div class="col-md-4">
                <div class="css-box">
                    <div class="head-table">
                        <div class="head-title">
                            <a :href="link_overview" target="_blank">Overview</a>
                        </div>
                        <div class="head-btn">                            
                            <i class="fas fa-save" v-on:click="save_data('overview')"></i>
                        </div>
                    </div>
                    <div class="table-setting">

                        <table class="table text-center">
                            <thead>
                                <tr>
                                    <th scope="col" style="width: 10%">#</th>
                                    <th scope="col" style="width: 50%">Title</th>
                                    <th scope="col" style="width: 30%">Time(SEC)</th>
                                    <th scope="col" style="width: 10%">#</th>
                                </tr>
                            </thead>
                            <tbody>
                                <tr v-for="(item, index) in setting_list">
                                    <th scope="row" class="btn-updown d-grid gap-2">
                                        <i class="fas fa-caret-square-up" v-on:click="top_row(index)"></i>
                                        <i class="fas fa-caret-square-down" v-on:click="below_row(index)"></i>
                                    </th>
                                    <td>
                                        <select class="form-select" id="txt_title" aria-label="Select Title" v-model="item.title">
                                            <option value="">Select</option>
                                            <option value="1">Yesterday</option>
                                            <option value="2">Today</option>
                                            <option value="3">Tomorrow</option>
                                            <option value="4">This Week</option>
                                            <option value="5">Next Week</option>
                                            <option value="6">This Month</option>
                                            <option value="7">Next Month</option>
                                        </select>
                                    </td>
                                    <td>
                                        <input type="number" id="txt_time" class="form-control" min="0" v-model="item.time" />
                                    </td>
                                    <th class="btn-remove">
                                        <i class="fas fa-minus-square" v-on:click="remove_row(index)"></i>
                                    </th>
                                </tr>

                            </tbody>
                        </table>

                    </div>

                    <div class="add-row" v-on:click="add_row()">
                        <i class="fas fa-plus"></i>
                    </div>
                </div>               

            </div>
        </div>
    </div>

    @*<i v-on:click="backTotop" id="toTop" class="fas fa-arrow-alt-circle-up backTotop"></i>*@

</div>

@Scripts.Render("~/Scripts/bootstrap-select.min.js")

<script>
    // ------------------------------ VUE JS ------------------------------ //
    const { createApp } = Vue

    let DTable = ''
    let Update_ID = ''

        createApp({
            data() {
                return {
                    role: '@Session["ROLE"].ToString()',
                    status: '@Session["STATUS"].ToString()',

                    setting_list: [],
                    groupList: [],
                    slt_group: '',

                    id_group: '@ViewBag.Data.param_id',
                    link_overview: '@Url.Action("Group", "Dashboard", new { id = @ViewBag.Data.param_id })',
                }
            },
            watch: {

            },
            mounted() {

                let self = this

            },
            async created() {

                let self = this

                await self.getData()

                await self.getGroup()

            },
            methods: {
                backTotop() {
                    window.scrollTo({
                        top: 0,
                        behavior: 'smooth'
                    })
                },
                add_row() {
                    const self = this;

                    self.setting_list.splice(self.setting_list.length, 0, {
                        title: '',
                        time: 10
                    });
                },
                remove_row(index) {
                    const self = this;

                    self.setting_list.splice(index, 1)[0];
                },
                top_row(index) {
                    const self = this;

                    const temp_arr_1 = self.setting_list[index];

                    if (index > 0) {
                        self.setting_list.splice(index, 1, self.setting_list[index - 1]);
                        self.setting_list.splice(index - 1, 1, temp_arr_1);
                    }
                },
                below_row(index) {
                    const self = this;

                    const temp_arr_1 = self.setting_list[index];

                    if (index < self.setting_list.length - 1 ) {
                        self.setting_list.splice(index, 1, self.setting_list[index + 1]);
                        self.setting_list.splice(index + 1, 1, temp_arr_1);
                    }
                },
                save_data(type) {
                    const self = this;

                    let check = true;

                    if (self.setting_list.length > 0) {

                        self.setting_list.forEach(function (value, i) {
                            if (value.title == '' || value.time <= 0) {
                                check = false;
                            }
                        });

                        if (check == true) {
                            $.ajax({
                                url: "@Url.Action("AddItem_Dashboard", "lookup")",
                                type: "POST",
                                data: {
                                    data_upload: self.setting_list,
                                    item_type: type
                                },
                                success: async function (result) {
                                    if (result.success) {
                                        await swal({
                                            title: "Alert",
                                            text: result.Message,
                                            type: "success",
                                            timer: 1200,
                                            showCancelButton: false,
                                            showConfirmButton: false
                                        })

                                        await self.getData()

                                    } else {
                                        swal({
                                            title: "Alert",
                                            text: result.Message,
                                            type: "warning",
                                            timer: 1500,
                                            showCancelButton: false,
                                            showConfirmButton: false
                                        })
                                    }

                                }
                            });
                        } else {
                            swal({
                                title: "Alert",
                                text: 'Please fill out the information completely',
                                type: "warning",
                                timer: 1500,
                                showCancelButton: false,
                                showConfirmButton: false
                            })
                        }
                    } else {
                        swal({
                            title: "Alert",
                            text: 'Please add at least 1 item',
                            type: "warning",
                            timer: 1500,
                            showCancelButton: false,
                            showConfirmButton: false
                        })
                    }

                  
                },
                 async getData() {

                     const self = this;

                     self.setting_list = []

                    await $.ajax({
                        url: "@Url.Action("ListItem_Dashboard", "lookup")",
                        type: "POST",
                        data: {},
                        success: function (result) {
                            if (result.success) {

                                result.data.forEach(function (value, i) {
                                    if (value.TYPE == 'overview') {
                                        self.setting_list.splice(self.setting_list.length, 0, {
                                            title: value.TITLE,
                                            time: value.TIME
                                        });
                                    }
                                });
                            }
                        }
                     });
                },
                 async getGroup() {

                  let self = this;

                    await $.ajax({
                        url: "@Url.Action("SelectItem_GROUP_WC_ByWC", "lookup")",
                        type: "POST",
                        data: {},
                        success: function (result) {
                            if (result.success) {

                                self.groupList = result.data

                                const arr = result.data;
                            
                                self.slt_group = '@Session["GROUP_ID"].ToString()';

                                if (self.slt_group == "") {
                                    self.slt_group = result.data[0].GROUP_ID
                                }

                                const index = arr.map(object => object.GROUP_ID).indexOf(self.slt_group);

                                const arrSelect = arr[index];

                                if (arrSelect.MENU_1 == 'N') {
                                    $('#lk-menu-2').hide();
                                }
                                if (arrSelect.MENU_2 == 'N') {
                                    $('#lk-menu-3').hide();
                                }
                                if (arrSelect.MENU_3 == 'N') {
                                    $('#lk-menu-1').hide();
                                }
                                if (arrSelect.MENU_5 == 'N') {
                                    $('#lk-menu-4').hide();
                                }
                                if (arrSelect.MENU_3 == 'N' && arrSelect.MENU_4 == 'N' && arrSelect.MENU_5 == 'N') {
                                    $('#lk-menu-5').hide();
                                }
                                if (arrSelect.MENU_1 == 'N' && arrSelect.MENU_2 == 'N' && arrSelect.MENU_4 == 'N' && arrSelect.MENU_5 == 'N') {
                                    $('#lk-menu-6').hide();
                                }

                            }

                        }
                     });

                     await $('#slt_group').selectpicker('destroy');
                     await $('#slt_group').selectpicker('render');
                     await $("#slt_group").selectpicker("val", self.slt_group)
                },
                 async selectGroup(gID) {

                    await $.ajax({
                        url: "@Url.Action("Select_GROUP", "lookup")",
                        type: "POST",
                        data: { item_group: gID},
                        success: function (result) {
                            if (result.success) {
                                window.open("@Url.Action("Dashboard", "Lookup")","_self")
                            }
                        }
                    });
                }
            }
    }).mount('#MainApp')

    $('#nav-link-master').addClass('active');

</script>
