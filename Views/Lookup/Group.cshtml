<script>
    // ------------------------------ VUE JS ------------------------------ //
    const { createApp } = Vue

        createApp({
            data() {
                return {
                    headers: [
                        { text: "Group ID", value: "ITEM_ID", sortable: true },
                        { text: "Group Name", value: "ITEM_NAME", sortable: true },
                        { text: "WC List", value: "ITEM_WC", sortable: true },
                        { text: "Update By", value: "UPDATE_BY", sortable: true },
                        { text: "Update Date", value: "UPDATE_DATE", sortable: true },
                        { text: "Status", value: "IS_USE", sortable: true },
                        { text: "Tools", value: "tool", sortable: false },
                    ],
                    items: [],
                    searchValue: '',
                    sortBy: ["ITEM_NAME"],
                    sortType: ["asc"],

                    role: '@Session["ROLE"].ToString()',
                    status: '@Session["STATUS"].ToString()',

                    slt_id: '',
                    slt_name: '',
                    slt_wc: [],
                    slt_staff: [],

                    slt_menu_man: 'Y',
                    slt_menu_mc: 'Y',
                    slt_menu_mold: 'Y',
                    slt_menu_met: 'Y',
                    slt_menu_part: 'Y',
                    slt_use : 'Y',


                    wcList: [],
                    staffList: [],

                    IsAdd: true,
                    dataTable: null,
                }
            },
            components: {
                EasyDataTable: window['vue3-easy-data-table'],
            },
            watch: {

            },
            mounted() {

                let self = this

            },
            async created() {

                let self = this

                await self.get_list()
                await self.getWC()
                await self.deleteOver()
                await $('#txt_wc').selectpicker('destroy');
                await $('#txt_wc').selectpicker('render');

            },
            methods: {
                backTotop() {
                    window.scrollTo({
                        top: 0,
                        behavior: 'smooth'
                    })
                },
                async get_list() {

                    let self = this;

                    await $.ajax({
                        url: '@Url.Action("ListItem_Group", "lookup")',
                        type: "POST",
                        data: {},
                        success: function (result) {
                            if (result.success) {
                                self.items = result.data
                            } else {
                                self.items = []
                            }

                        }
                    });
                },
                async Open_Modal(status, id) {

                    let self = this

                    let el = document.querySelector('#Item-modal');
                    let modal = bootstrap.Modal.getOrCreateInstance(el);

                    if (status == 'Add') {
                        self.IsAdd = true

                        self.slt_name = ''
                        self.slt_wc = []
                        $("#txt_wc").selectpicker("val", [])

                        slt_menu_man = 'Y';
                        slt_menu_mc= 'Y';
                        slt_menu_mold= 'Y';
                        slt_menu_met= 'Y';
                        slt_menu_part= 'Y';
                        self.slt_use = 'Y';

                         $.ajax({
                            url: "@Url.Action("AddItem_Group", "lookup")",
                            type: "POST",
                            data: {
                                item_name: self.slt_name,
                            },
                            success: function (result) {
                                if (result.success) {

                                    self.id = result.data[0].ID

                                    modal.show()
                                }
                            }
                        });

                        modal.show()
                  
                    } else {

                        self.IsAdd = false
                        self.id = id;

                         await $.ajax({
                             url: "@Url.Action("SelectItem_Group", "lookup")",
                             type: "POST",
                             data: { item_id: id },
                             success: function (result) {
                                 if (result.success) {

                                     $("#txt_wc").selectpicker("val", result.data[0]["ITEM_WC"].split(","))

                                     self.slt_name = result.data[0]["ITEM_NAME"]
                                     self.slt_wc = result.data[0]["ITEM_WC"].split(",")

                                     self.slt_menu_man = result.data[0]["MENU_1"];
                                     self.slt_menu_mc = result.data[0]["MENU_2"];
                                     self.slt_menu_mold = result.data[0]["MENU_3"];
                                     self.slt_menu_met = result.data[0]["MENU_4"];
                                     self.slt_menu_part = result.data[0]["MENU_5"];
                                     self.slt_use = result.data[0]["IS_USE"];

                                    modal.show()

                                 }
                             }
                        });

                    }
                },
                async saveItem() {

                    let self = this

                    let el = document.querySelector('#Item-modal');
                    let modal = bootstrap.Modal.getOrCreateInstance(el);

                    if (self.slt_name == '' || self.slt_wc.toString() == '') {
                        alertBoxTime('Alert', 'Please fill out the information completely', 'warning', 1100, '', '')
                    } else {

                        $("#btn-save").html('<i class="fas fa-sync fa-spin"></i>');
                        $("#btn-save").prop('disabled', true);

                        $.ajax({
                                url: "@Url.Action("EditItem_Group", "lookup")",
                                type: "POST",
                                data: {
                                    item_id: self.id,
                                    item_name: self.slt_name,
                                    item_wc: self.slt_wc.toString(),
                                    item_isUse: self.slt_use,
                                    item_menu1: self.slt_menu_man,
                                    item_menu2: self.slt_menu_mc,
                                    item_menu3: self.slt_menu_mold,
                                    item_menu4: self.slt_menu_met,
                                    item_menu5: self.slt_menu_part,
                                },
                                success: function (result) {
                                    if (result.success) {
                                        swal({
                                            title: "Alert",
                                            text: result.Message,
                                            type: "success",
                                            timer: 1200,
                                            showCancelButton: false,
                                            showConfirmButton: false
                                        })

                                        self.get_list()

                                        modal.hide();
                                    } else {
                                        swal({
                                            title: "Alert",
                                            text: result.Message,
                                            type: "warning",
                                            timer: 1500,
                                            showCancelButton: false,
                                            showConfirmButton: false
                                        })
                                    }

                                }
                            });
                    }

                    $("#btn-save").html('Save');
                    $("#btn-save").prop('disabled', false);

                },
                deleteItem(id) {

                    const self = this;

                     let fn = function (isConfirm) {
                         if (isConfirm) {
                             $.ajax({
                                 url: "@Url.Action("DeleteItem_Group", "lookup")",
                                 type: "POST",
                                 data: { item_id: id  },
                                 success: function (result) {
                                     if (result.success) {
                                         swal({
                                             title: "Alert",
                                             text: result.Message,
                                             type: "success",
                                             timer: 1000,
                                             showCancelButton: false,
                                             showConfirmButton: false
                                         })
                                         self.get_list();
                                     } else {
                                         swal({
                                             title: "Alert",
                                             text: result.responseText,
                                             type: "warning",
                                             timer: 1000,
                                             showCancelButton: false,
                                             showConfirmButton: false
                                         })
                                     }
                                 }
                             });
                         } else {
                         }
                    }

                    alertBoxConfirm("Alert", "Do you want to delete the information?", "", fn)

                },
                async getWC() {

                     let self = this;

                    await $.ajax({
                        url: "@Url.Action("Option_WC", "lookup")",
                        type: "POST",
                        data: {item_part:'' },
                        success: function (result) {
                            if (result.success) {

                                self.wcList = result.data

                            }

                        }
                    });
                },
                async deleteOver() {

                    await $.ajax({
                        url: "@Url.Action("Delete_Group_Over", "lookup")",
                        type: "POST",
                        data: {item_part:'' },
                        success: function (result) {
                            if (result.success) {
                            }
                        }
                    });
                },
                async cancelAdd() {
                    var self = this;

                    let el = document.querySelector('#Item-modal');
                    let modal = bootstrap.Modal.getOrCreateInstance(el);

                    if (self.IsAdd) {

                        await $.ajax({
                            url: '@Url.Action("DeleteItem_Group", "lookup")',
                            type: 'POST',
                            data: { item_id: self.id },
                            success: function (result) {
                                if (result.success) {
                                }
                            }
                        });
                    }

                    await modal.hide();
                },
                async remove_select_wc(index) {
                    const self = this;
                    await self.slt_wc.splice(index, 1); 
                    await $("#txt_wc").selectpicker("val", (self.slt_wc))
                }

            }
    }).mount('#MainApp')

