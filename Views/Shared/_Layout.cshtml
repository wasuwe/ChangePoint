                type: "POST",
                data: {},
                success: function (result) {

                    window.open("@Url.Action("index", "login")","_self")

                }
            });
        });

     //----------------------------- Sweet Alert --------------------------------------//

        function alertBox(title = "", text = "", icon = "success", customsClass = "", fn = "") {

            //type : warning, error, success, info

            swal({
                title: title,
                text: text,
                type: icon,
                customClass: customsClass,
                showCancelButton: false,
                showConfirmButton: true
            }, fn);
        }

        function alertBoxTime(title = "", text = "", icon = "success", time = 1100, customsClass = "", fn = "") {

            //type : warning, error, success, info

            //[your function] = function (isConfirm) {
            //    if (isConfirm) {
            //        swal({
            //            title: "Alert",
            //            text: "Success",
            //            type: "success",
            //            timer: 1000,
            //            showCancelButton: false,
            //            showConfirmButton: false
            //        })
            //    } else {

            //    }
            //}

            swal({
                title: title,
                text: text,
                type: icon,
                customClass: customsClass,
                timer: time,
                showCancelButton: false,
                showConfirmButton: false
            }, fn);
        }

        function alertBoxConfirm(title = "", text = "", customsClass = "", fn = "") {

            //[your function] = function (isConfirm) {
            //    if (isConfirm) {
            //        swal({
            //            title: "Alert",
            //            text: "Success",
            //            type: "success",
            //            timer: 1000,
            //            showCancelButton: false,
            //            showConfirmButton: false
            //        })
            //    } else {

            //    }
            //}
             swal({
                title: title,
                text: text,
                type: "warning",
                customClass: customsClass,
                showCancelButton: true,
                confirmButtonText: "Yes",
                cancelButtonText: "No",
                closeOnConfirm: false,
                 closeOnCancel: true
            }, fn );
        }

     //----------------------------- Sweet Alert --------------------------------------//

    </script>

