    <style>

        body {
            font-family: var(--bs-body-font-family) !important;
        }

        .LoginBox {
            display: flex;
            justify-content: center;
            align-items: center;
            height: 100vh;
            background: #f2f2f2;
        }

        .loginForm {
            width: 350px;
            /*height: 300px;*/
            /*border: solid 3px #eeeeee;*/
            padding: 90px 55px 33px;
            display: flex;
            align-items: center;
            flex-direction: column;
            position: relative;
            box-shadow: 0 5px 10px 0 rgb(0 0 0 / 10%);
            background: #fff;
            border-radius: 10px;
        }

        .LoginHR {
            width: 100%;
            position: relative;
            display: flex;
            align-items: center;
            justify-content: center;
        }

            .LoginHR hr {
                width: 100%;
            }

            .LoginHR label {
                position: absolute;
                background-color: #ffffff;
                padding: 0px 8px;
                font-weight: bold;
            }


        .LoginTitle {
            margin-bottom: 20px;
            font-size: 30px;
            font-weight: bold;
            display: flex;
        }

            .LoginTitle .LoginVisitor {
                width: 0px;
                overflow: hidden;
                transition: all 0.45s;
            }

                .LoginTitle .LoginVisitor.active {
                    width: 140px;
                }

            .LoginTitle .LoginMember {
                width: 0px;
                overflow: hidden;
                transition: all 0.45s;
            }

                .LoginTitle .LoginMember.active {
                    width: 130px;
                }

        .LoginInput {
            display: flex;
            grid-gap: 15px;
            align-items: center;
            margin-bottom: 20px;
        }

            .LoginInput.password {
                grid-gap: 20px;
            }

            .LoginInput input {
                width: 100%
            }

        .LoginButton {
            display: flex;
            align-items: center;
            justify-content: center;
            width: 100%;
            flex-direction: column;
            grid-gap: 10px;
            margin-bottom: 10px;
            margin: 10px 0;
        }

            .LoginButton button {
                width: 100%;
            }

        .ForgotPassowrd {
            font-size: 13px;
        }

            .ForgotPassowrd a {
                color: #838383;
            }

        .btnSwitch-2 {
            color: rgb(255, 184, 76);
        }

        .btnSwitch-1 {
            color: rgb(43, 52, 103);
        }

        .btnSwitch-1, .btnSwitch-2 {
            position: absolute;
            right: 149px;
            top: 35px;
            border: 2px solid;
            padding: 5px;
            border-radius: 100%;
            height: 50px;
            width: 50px;
            display: flex;
            align-items: center;
            justify-content: center;
            cursor: pointer;
            background-color: #ffffff;
            font-size: 30px;
        }



        /*.headbar-between {
            justify-content: space-between;
        }*/
        .headbar-search {
            grid-gap: 5px;
        }

        .btn-default {
            background: #eee;
        }

            .btn-default:hover {
                background: #d3d3d3 !important;
            }


        .MenuBox {
            display: flex;
            flex-wrap: wrap;
            grid-gap: 10px;
            justify-content: center;
            margin-top: 20px;
        }

            .MenuBox .MenuItem {
                height: 150px;
                border: solid 1px #00000e;
                width: 24%;
                display: flex;
                align-items: center;
                justify-content: center;
                border-radius: 8px;
                background: #eee;
                font-size: 40px;
            }

        footer {
            position: absolute;
            bottom: 0;
            width: 100%;
            background: #919191;
            padding: 10px;
            margin: 0;
        }

            footer p {
                margin: 0;
                font-size: 15px;
            }

        /*---------- table Page ----------*/
        .tables-page-head {
            margin-top: 30px;
            margin-bottom: 30px;
            display: flex;
            flex-direction: row;
            justify-content: space-between;
            align-items: center;
        }

            .tables-page-head .haed-title {
                font-size: 35px;
                font-weight: bold;
            }

            .tables-page-head .haed-fn a {
                font-size: 30px;
                color: #47c513;
                transition: all 0.4s;
            }

                .tables-page-head .haed-fn a i {
                    transition: all 0.4s;
                }

                .tables-page-head .haed-fn a:hover i {
                    transform: scale(1.2)
                }


        tbody a {
            text-decoration: unset !important;
            color: #000000;
        }

        .form-switch .form-check-input {
            width: 4em;
            height: 2em;
            margin: 0;
            margin-right: 20px;
        }

        #IsUse {
            position: absolute;
            right: 0;
            top: 10px;
        }

        /*---------- table Page ----------*/

        .cancel.btn.btn-lg.btn-default {
            color: #fff !important;
            background-color: #6c757d !important;
            border-color: #6c757d !important;
        }

        .title-name {
            min-width: 100px;
        }

        .dselect-wrapper {
            border: unset;
            padding: 0;
        }

        div#MyClockDisplay {
            color: #ffffff;
            font-size: 15px;
            font-weight: bold;
        }

        #unread-msg {
            display: none;
        }
    </style>

