                async get_list() {

                    let self = this;

                    let date_start = '';
                    let date_stop = '';
                     
                    if (self.date_day != null) {
                        const dateStart = await self.date_day[0];
                        const dateEnd = await self.date_day[1];

                        let yyyy = await dateStart.getFullYear();
                        let MM = await ('0' + (dateStart.getMonth() + 1)).slice(-2);
                        let dd = await ('0' + dateStart.getDate()).slice(-2);
                        date_start = await dd + "-" + MM + "-" + yyyy;

                        yyyy = await dateEnd.getFullYear();
                        MM = await ('0' + (dateEnd.getMonth() + 1)).slice(-2);
                        dd = await ('0' + dateEnd.getDate()).slice(-2);
                        date_stop = await dd + "-" + MM + "-" + yyyy;
                    }
                  

                    await $.ajax({
                        url: '@Url.Action("List_Waiting_Confirm", "Waiting")',
                        type: "POST",
                        data: {
                            date_start: date_start, date_stop: date_stop,
                            filter_type: self.filter_type.map(d => `'${d}'`).join() ,
                            filter_shift: self.filter_shift.map(d => `'${d}'`).join() ,
                            filter_status: self.filter_status.map(d => `'${d}'`).join(),
                        },
                        success: function (result) {
                            if (result.success) {
                                self.items = result.data

                                let i = 0;
                                self.items.forEach((item) => {

                                    let dateParts = item.CREATE_DATE.split(" ")[0].split("/");
                                    let day = parseInt(dateParts[0], 10);
                                    let month = parseInt(dateParts[1], 10);
                                    let year = parseInt(dateParts[2], 10);

                                    let date = new Date(`${year}-${month}-${day}`);
                                    let timestamp = date.getTime();
                                    
                                    self.items[i].CREATE_DATE_STAMP = timestamp

                                    dateParts = item.CHANGE_POINT_DATE.split("/");
                                    day = parseInt(dateParts[0], 10);
                                    month = parseInt(dateParts[1], 10);
                                    year = parseInt(dateParts[2], 10);

                                    date = new Date(`${year}-${month}-${day}`);
                                    timestamp = date.getTime();

                                    self.items[i].CHANGE_POINT_DATE_STAMP = timestamp

                                    i++

                                })

                            } else {
                                self.items = []
                            }
                        }
                    });
                },
