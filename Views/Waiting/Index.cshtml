                 async get_detail_risk(type) {

                     const self = this;

                     await $.ajax({
                        url: "@Url.Action("Option_Details", "lookup")",
                        type: "POST",
                         data: { filter_type: type },
                        success: async function (result) {
                            if (result.success) {

                                const inputData = await result.data

                                self.details_list = await result.data

                                const transformedData = await {};

                                await inputData.forEach(item => {
                                    const id = item.ITEM_ID;
                                    const detail = item.ITEM_DETAIL;
                                    const risk = item.ITEM_RISK;
                                    const category = item.ITEM_CATEGORY_NAME;

                                    if (category in transformedData) {
                                        transformedData[category].list.push(
                                            {
                                                id: id,
                                                detail: detail,
                                                risk: risk,
                                            }
                                        );
                                    } else {
                                        transformedData[category] = {
                                            category: category,
                                            list: [
                                                {
                                                    id: id,
                                                    detail: detail,
                                                    risk: risk,
                                                }
                                            ]
                                        };
                                    }
                                });

                                self.details_option = await Object.values(transformedData);
                            
                                 await $('#txt_details').selectpicker('destroy');
                                await $('#txt_details').selectpicker('render');

                            }

                        }
                     });

